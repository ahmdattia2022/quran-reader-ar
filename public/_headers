# Cloudflare Pages applies these headers to matching paths at the edge.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# ── Site-wide security + privacy ────────────────────────────────────────
/*
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net data:; img-src 'self' data: blob:; media-src 'self' https://cdn.islamic.network; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.axiom.co https://cdn.islamic.network; manifest-src 'self'; worker-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

# ── Immutable hashed build outputs — cache for one year ─────────────────
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# ── HTML pages — short TTL, revalidate on each visit ────────────────────
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# ── Sitemap & robots — short TTL ────────────────────────────────────────
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/sitemap-0.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600

# ── Content integrity hash — freshness matters, one-day cache ───────────
/quran-hash.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# ── Search index — rebuilt on deploy, safe to cache for a day ───────────
/search-index.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8

# ── Daily ayahs — rebuilt on deploy, cache for a day ───────────────────
/daily-ayahs.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8

# ── Extended tafsir editions — rarely change; one-week cache ───────────
/tafsirs/*
  Cache-Control: public, max-age=604800
  Content-Type: application/json; charset=utf-8

# ── PWA manifest + service worker ──────────────────────────────────────
/manifest.webmanifest
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json; charset=utf-8
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# ── PWA icons — long cache, content rarely changes ─────────────────────
/icon-192.png
  Cache-Control: public, max-age=2592000
/icon-512.png
  Cache-Control: public, max-age=2592000
/icon-maskable-512.png
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000

# ── IndexNow key file — served as plain text ────────────────────────────
/9a8f2e5c4d1b3a7e6f0d9c8b2a1e5f4d.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# ── Favicon — aggressive cache ──────────────────────────────────────────
/favicon.svg
  Cache-Control: public, max-age=604800
