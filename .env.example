# Supabase — optional. When set, enables email magic-link auth and
# cross-device sync of bookmarks / settings / prayer location.
#
# If left blank, the app runs in local-only mode (same as before) —
# the auth button and sync badge won't appear in the UI.
#
# Get these from: Supabase Dashboard → Settings → API
#   - Project URL  → PUBLIC_SUPABASE_URL
#   - Project API keys → anon public → PUBLIC_SUPABASE_ANON_KEY
#
# Both values are safe to expose publicly (they're client-side keys
# protected by Row Level Security in the database).

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
