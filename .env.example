# Supabase — optional. When set, enables email magic-link auth and
# cross-device sync of bookmarks / settings / prayer location.
#
# If left blank, the app runs in local-only mode (same as before) —
# the auth button and sync badge won't appear in the UI.
#
# Get these from: Supabase Dashboard → Settings → API
#   - Project URL  → PUBLIC_SUPABASE_URL
#   - Project API keys → anon public → PUBLIC_SUPABASE_ANON_KEY
#
# Both values are safe to expose publicly (they're client-side keys
# protected by Row Level Security in the database).

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# ─── Axiom — optional remote log sink (monitoring/debugging) ───
#
# Free tier: 500MB/month ingest, 30-day retention (auto-delete).
# Sign up at axiom.co with GitHub (no card required), create a dataset
# named "quran-reader" (or anything), then create an API token with
# the "Ingest" scope only (NOT "Query" — that scope would be unsafe to
# expose). Tokens with only Ingest scope can write logs but cannot read
# them, similar to a Sentry DSN.
#
# If these are left blank, the app stores logs ONLY in localStorage
# (viewable at /debug/) — no data leaves the browser.

PUBLIC_AXIOM_DATASET=
PUBLIC_AXIOM_TOKEN=

# ─── App version — shows up in logs + status display ───
# Pass at build time (e.g., via CI): PUBLIC_APP_VERSION=$(git rev-parse --short HEAD) npm run build
PUBLIC_APP_VERSION=
