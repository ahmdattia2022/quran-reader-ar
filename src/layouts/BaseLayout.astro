---
import '../styles/global.css';
import ReadingSettings from '../components/ReadingSettings.astro';
import PWAInstaller from '../components/PWAInstaller.astro';
import AuthModal from '../components/AuthModal.astro';
import SyncBadge from '../components/SyncBadge.astro';
import KeyboardHelp from '../components/KeyboardHelp.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}

const { title, description, canonical, ogType = 'website', jsonLd, noindex = false } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5" />
  <meta name="theme-color" content="#064e3b" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Language / locale signals -->
  <meta http-equiv="Content-Language" content="ar" />
  <meta name="language" content="Arabic" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content="ar_AR" />
  <meta property="og:site_name" content="القرآن الكريم" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts: Amiri Quran for Uthmani script, Noto Sans Arabic for UI -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.islamic.network" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Amiri+Quran&family=Noto+Sans+Arabic:wght@400;500;600;700&family=Amiri:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon + PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="القرآن" />
  <meta name="mobile-web-app-capable" content="yes" />

  <!-- Robots / SEO -->
  {noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <>
      <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
      <meta name="googlebot" content="index, follow" />
      <meta name="bingbot" content="index, follow" />
    </>
  )}

  <!-- Sitemap discovery -->
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <!-- Alternate hreflang for Arabic (reinforces language targeting) -->
  <link rel="alternate" hreflang="ar" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <!-- Google Search Console verification (meta tag method — avoids Cloudflare's .html stripping) -->
  <meta name="google-site-verification" content="PASTE_YOUR_CODE_HERE" />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
</head>
<body class="flex min-h-dvh flex-col">
  <header class="sticky top-0 z-40 border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-5xl items-center justify-between gap-2 px-3 py-3 sm:px-6">
      <a href="/" class="flex min-w-0 items-center gap-2 font-bold text-white sm:gap-2.5">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 shadow-lg shadow-emerald-500/30 sm:h-9 sm:w-9">
          <svg class="h-4 w-4 text-white sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <span class="truncate text-base sm:text-lg">القرآن الكريم</span>
      </a>

      <!-- Desktop / tablet inline nav (sm+) -->
      <nav class="hidden items-center gap-0.5 text-sm sm:flex sm:gap-1">
        <a href="/" class="rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:px-2.5">السور</a>
        <a href="/mushaf/" class="rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:px-2.5">المصحف</a>
        <a href="/juz/" class="rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:px-2.5">الأجزاء</a>
        <a href="/duaa/" class="hidden rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 md:inline-block md:px-2.5">الأدعية</a>
        <a href="/khatm/" class="hidden rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 md:inline-block md:px-2.5">الختمة</a>
        <a href="/awqat/" class="rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:px-2.5">المواقيت</a>
        <a href="/search/" class="flex h-9 w-9 items-center justify-center rounded-md text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400" aria-label="بحث">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
        </a>
        <a href="/bookmarks/" class="flex h-9 w-9 items-center justify-center rounded-md text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400" aria-label="الإشارات المرجعية">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </a>
      </nav>

      <!-- Mobile compact nav (< sm): icons + hamburger -->
      <div class="flex items-center gap-0.5 sm:hidden">
        <a href="/search/" class="flex h-10 w-10 items-center justify-center rounded-md text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400" aria-label="بحث">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
        </a>
        <a href="/bookmarks/" class="flex h-10 w-10 items-center justify-center rounded-md text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400" aria-label="الإشارات المرجعية">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </a>
        <button
          id="nav-menu-btn"
          type="button"
          class="flex h-10 w-10 items-center justify-center rounded-md text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400"
          aria-label="فتح القائمة"
          aria-expanded="false"
          aria-controls="nav-drawer"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile drawer (slides in from the start side — right for RTL) -->
  <div
    id="nav-drawer"
    class="fixed inset-0 z-50 hidden sm:hidden"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="القائمة الرئيسية"
  >
    <div id="nav-drawer-backdrop" class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm"></div>
    <aside
      id="nav-drawer-panel"
      class="absolute inset-y-0 left-0 flex h-full w-72 max-w-[82vw] flex-col overflow-y-auto border-r border-slate-800 bg-slate-900 shadow-2xl"
    >
      <div class="flex items-center justify-between gap-3 border-b border-slate-800 px-5 py-4">
        <div class="flex items-center gap-2 font-bold text-white">
          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-teal-600">
            <svg class="h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </span>
          <span class="text-base">القرآن الكريم</span>
        </div>
        <button
          id="nav-drawer-close"
          type="button"
          class="flex h-10 w-10 items-center justify-center rounded-md text-slate-400 transition hover:bg-slate-800 hover:text-white"
          aria-label="إغلاق القائمة"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <nav class="flex-1 p-3">
        <ul class="space-y-1">
          <li><a href="/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">فهرس السور</a></li>
          <li><a href="/mushaf/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">المصحف</a></li>
          <li><a href="/juz/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">الأجزاء</a></li>
          <li><a href="/duaa/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">أدعية من القرآن</a></li>
          <li><a href="/khatm/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">خطة الختمة</a></li>
          <li><a href="/awqat/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">مواقيت الصلاة والقبلة</a></li>
          <li><a href="/search/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">البحث في القرآن</a></li>
          <li><a href="/bookmarks/" class="block rounded-lg px-4 py-3 text-base text-slate-200 transition hover:bg-slate-800 hover:text-emerald-300">الإشارات المرجعية</a></li>
          <li class="pt-2"><div class="my-2 border-t border-slate-800"></div></li>
          <li><a href="/about/" class="block rounded-lg px-4 py-2.5 text-sm text-slate-400 transition hover:bg-slate-800 hover:text-emerald-300">عن المصحف</a></li>
          <li><a href="/privacy/" class="block rounded-lg px-4 py-2.5 text-sm text-slate-400 transition hover:bg-slate-800 hover:text-emerald-300">سياسة الخصوصية</a></li>
        </ul>
      </nav>
    </aside>
  </div>

  <script is:inline>
    (function () {
      const drawer = document.getElementById('nav-drawer');
      const openBtn = document.getElementById('nav-menu-btn');
      const closeBtn = document.getElementById('nav-drawer-close');
      const backdrop = document.getElementById('nav-drawer-backdrop');
      if (!drawer || !openBtn) return;

      function openDrawer() {
        drawer.classList.remove('hidden');
        drawer.setAttribute('aria-hidden', 'false');
        openBtn.setAttribute('aria-expanded', 'true');
        document.documentElement.style.overflow = 'hidden';
      }
      function closeDrawer() {
        drawer.classList.add('hidden');
        drawer.setAttribute('aria-hidden', 'true');
        openBtn.setAttribute('aria-expanded', 'false');
        document.documentElement.style.overflow = '';
      }

      openBtn.addEventListener('click', openDrawer);
      closeBtn?.addEventListener('click', closeDrawer);
      backdrop?.addEventListener('click', closeDrawer);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !drawer.classList.contains('hidden')) closeDrawer();
      });
      // Close drawer if viewport grows past sm (user rotated or resized)
      const mq = window.matchMedia('(min-width: 640px)');
      (mq.addEventListener || mq.addListener).call(mq, 'change', (e) => {
        if (e.matches && !drawer.classList.contains('hidden')) closeDrawer();
      });
    })();
  </script>

  <main class="flex-1">
    <slot />
  </main>

  <!-- Floating reading settings — font size, line height, theme -->
  <ReadingSettings />

  <!-- PWA install button + SW registration -->
  <PWAInstaller />

  <!-- Sync badge (only shows when signed in) + auth modal (hidden unless opened) -->
  <SyncBadge />
  <AuthModal />

  <!-- Global keyboard shortcuts (? to open help modal, / focuses search, Esc closes) -->
  <KeyboardHelp />

  <!-- Start the sync engine (no-op if Supabase env vars aren't set) -->
  <script>
    import { initSync } from '../lib/sync';
    import { isConfigured } from '../lib/supabase';

    initSync();

    // When reading_settings or prayer_settings pull from cloud, re-apply
    // them so the UI picks up the new values without a full reload.
    window.addEventListener('qr:data-cloud-pulled', (e: any) => {
      const key = e.detail?.key;
      if (key === 'reading_settings') {
        try {
          const s = JSON.parse(localStorage.getItem('qr_reading_settings_v1') || '{}');
          const root = document.documentElement;
          if (s.theme) {
            const pref = s.theme;
            let effective: string = pref;
            if (pref === 'system' || (pref !== 'light' && pref !== 'dark' && pref !== 'night')) {
              effective = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            root.setAttribute('data-theme', effective);
            root.setAttribute('data-theme-pref', pref);
          }
          if (s.fontScale) root.style.setProperty('--font-scale', String(s.fontScale));
          if (s.lineScale) root.style.setProperty('--line-height-scale', String(s.lineScale));
        } catch {}
      }
    });

    // Expose a helper for surfacing the auth modal from in-app CTAs
    (window as any).qrOpenAuth = () => window.dispatchEvent(new CustomEvent('qr:open-auth'));
  </script>

  <!-- Restore theme before first paint to avoid FOUC. Mirrors the
       resolveEffective() logic in ReadingSettings: 'system' follows the
       OS preference via prefers-color-scheme. -->
  <script is:inline>
    (function () {
      try {
        var raw = localStorage.getItem('qr_reading_settings_v1');
        var s = raw ? JSON.parse(raw) : {};
        var pref = s.theme || 'system';
        var effective = pref;
        if (pref === 'system' || (pref !== 'light' && pref !== 'dark' && pref !== 'night')) {
          effective = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', effective);
        document.documentElement.setAttribute('data-theme-pref', pref);
        if (s.fontScale) document.documentElement.style.setProperty('--font-scale', String(s.fontScale));
        if (s.lineScale) document.documentElement.style.setProperty('--line-height-scale', String(s.lineScale));
      } catch (e) {}
    })();
  </script>

  <footer class="border-t border-slate-800/60 bg-slate-950/60">
    <div class="mx-auto max-w-5xl px-4 py-8 text-sm text-slate-400 sm:px-6">
      <nav class="mb-6 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs">
        <a href="/" class="hover:text-emerald-400">السور</a>
        <a href="/mushaf/" class="hover:text-emerald-400">المصحف</a>
        <a href="/juz/" class="hover:text-emerald-400">الأجزاء</a>
        <a href="/duaa/" class="hover:text-emerald-400">الأدعية</a>
        <a href="/khatm/" class="hover:text-emerald-400">الختمة</a>
        <a href="/awqat/" class="hover:text-emerald-400">المواقيت</a>
        <a href="/search/" class="hover:text-emerald-400">البحث</a>
        <a href="/bookmarks/" class="hover:text-emerald-400">الإشارات</a>
        <a href="/about/" class="hover:text-emerald-400">عن المصحف</a>
        <a href="/privacy/" class="hover:text-emerald-400">الخصوصية</a>
      </nav>
      <div class="text-center">
        <p>
          مصحف إلكتروني برواية حفص عن عاصم · نص عثماني
        </p>
        <p class="mt-2 text-xs text-slate-500">
          البيانات مصدرها <a href="https://alquran.cloud" class="underline hover:text-emerald-400" rel="noopener" target="_blank">alquran.cloud</a>
          · التلاوة من <a href="https://cdn.islamic.network" class="underline hover:text-emerald-400" rel="noopener" target="_blank">islamic.network</a>
        </p>
        <p class="mt-3 text-xs text-slate-600">
          &copy; {new Date().getFullYear()} · نسأل الله أن ينفع به
        </p>
      </div>
    </div>
  </footer>
</body>
</html>
