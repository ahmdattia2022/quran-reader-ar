---
import '../styles/global.css';
import ReadingSettings from '../components/ReadingSettings.astro';
import PWAInstaller from '../components/PWAInstaller.astro';
import AuthModal from '../components/AuthModal.astro';
import SyncBadge from '../components/SyncBadge.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}

const { title, description, canonical, ogType = 'website', jsonLd, noindex = false } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5" />
  <meta name="theme-color" content="#064e3b" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Language / locale signals -->
  <meta http-equiv="Content-Language" content="ar" />
  <meta name="language" content="Arabic" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content="ar_AR" />
  <meta property="og:site_name" content="القرآن الكريم" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts: Noto Sans Arabic for UI, Amiri Quran loaded in CSS -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preconnect" href="https://cdn.islamic.network" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700&family=Amiri:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon + PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="القرآن" />
  <meta name="mobile-web-app-capable" content="yes" />

  <!-- Robots / SEO -->
  {noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <>
      <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
      <meta name="googlebot" content="index, follow" />
      <meta name="bingbot" content="index, follow" />
    </>
  )}

  <!-- Sitemap discovery -->
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <!-- Alternate hreflang for Arabic (reinforces language targeting) -->
  <link rel="alternate" hreflang="ar" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <!-- Google Search Console verification (meta tag method — avoids Cloudflare's .html stripping) -->
  <meta name="google-site-verification" content="PASTE_YOUR_CODE_HERE" />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
</head>
<body class="flex min-h-dvh flex-col">
  <header class="sticky top-0 z-40 border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3 sm:px-6">
      <a href="/" class="flex items-center gap-2.5 font-bold text-white">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 shadow-lg shadow-emerald-500/30">
          <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <span class="text-lg">القرآن الكريم</span>
      </a>
      <nav class="flex items-center gap-0.5 text-sm sm:gap-1">
        <a href="/" class="rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:px-2.5">
          السور
        </a>
        <a href="/mushaf/" class="rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:px-2.5">
          المصحف
        </a>
        <a href="/juz/" class="hidden rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:inline-block sm:px-2.5">
          الأجزاء
        </a>
        <a href="/awqat/" class="rounded-md px-2 py-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400 sm:px-2.5">
          المواقيت
        </a>
        <a href="/search/" class="rounded-md p-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400" aria-label="بحث">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/>
          </svg>
        </a>
        <a href="/bookmarks/" class="rounded-md p-1.5 text-slate-300 transition hover:bg-slate-800 hover:text-emerald-400" aria-label="الإشارات المرجعية">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
          </svg>
        </a>
      </nav>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <!-- Floating reading settings — font size, line height, theme -->
  <ReadingSettings />

  <!-- PWA install button + SW registration -->
  <PWAInstaller />

  <!-- Sync badge (only shows when signed in) + auth modal (hidden unless opened) -->
  <SyncBadge />
  <AuthModal />

  <!-- Start the sync engine (no-op if Supabase env vars aren't set) -->
  <script>
    import { initSync } from '../lib/sync';
    import { isConfigured } from '../lib/supabase';

    initSync();

    // When reading_settings or prayer_settings pull from cloud, re-apply
    // them so the UI picks up the new values without a full reload.
    window.addEventListener('qr:data-cloud-pulled', (e: any) => {
      const key = e.detail?.key;
      if (key === 'reading_settings') {
        try {
          const s = JSON.parse(localStorage.getItem('qr_reading_settings_v1') || '{}');
          const root = document.documentElement;
          if (s.theme) root.setAttribute('data-theme', s.theme);
          if (s.fontScale) root.style.setProperty('--font-scale', String(s.fontScale));
          if (s.lineScale) root.style.setProperty('--line-height-scale', String(s.lineScale));
        } catch {}
      }
    });

    // Expose a helper for surfacing the auth modal from in-app CTAs
    (window as any).qrOpenAuth = () => window.dispatchEvent(new CustomEvent('qr:open-auth'));
  </script>

  <!-- Restore theme before first paint to avoid flash -->
  <script is:inline>
    (function () {
      try {
        var raw = localStorage.getItem('qr_reading_settings_v1');
        if (raw) {
          var s = JSON.parse(raw);
          if (s.theme) document.documentElement.setAttribute('data-theme', s.theme);
          if (s.fontScale) document.documentElement.style.setProperty('--font-scale', String(s.fontScale));
          if (s.lineScale) document.documentElement.style.setProperty('--line-height-scale', String(s.lineScale));
        }
      } catch (e) {}
    })();
  </script>

  <footer class="border-t border-slate-800/60 bg-slate-950/60">
    <div class="mx-auto max-w-5xl px-4 py-8 text-center text-sm text-slate-400 sm:px-6">
      <p>
        مصحف إلكتروني برواية حفص عن عاصم · نص عثماني
      </p>
      <p class="mt-2 text-xs text-slate-500">
        البيانات مصدرها <a href="https://alquran.cloud" class="underline hover:text-emerald-400" rel="noopener" target="_blank">alquran.cloud</a>
        · التلاوة من <a href="https://cdn.islamic.network" class="underline hover:text-emerald-400" rel="noopener" target="_blank">islamic.network</a>
      </p>
      <p class="mt-3 text-xs text-slate-600">
        &copy; {new Date().getFullYear()} · نسأل الله أن ينفع به
      </p>
    </div>
  </footer>
</body>
</html>
