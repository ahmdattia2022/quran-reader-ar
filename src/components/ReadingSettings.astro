---
/**
 * Floating reading settings: font size scale, line-height scale, theme.
 * Applies CSS custom properties on <html> so changes are instant and
 * don't cause layout thrash. State persists to localStorage.
 */
---
<button
  id="rsOpen"
  type="button"
  aria-label="إعدادات القراءة"
  aria-expanded="false"
  aria-controls="rsPanel"
  class="fixed bottom-4 left-4 z-40 flex h-11 w-11 items-center justify-center rounded-full border border-slate-700 bg-slate-900/85 text-slate-200 shadow-lg backdrop-blur-md transition hover:border-emerald-500 hover:text-emerald-400 sm:bottom-6 sm:left-6"
>
  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 7h12M4 12h8M4 17h6M18 4l4 4-4 4M22 8h-8M18 14l4 4-4 4M22 18h-8"/>
  </svg>
</button>

<aside
  id="rsPanel"
  class="fixed bottom-20 left-4 z-40 hidden w-[calc(100vw-2rem)] max-w-xs rounded-xl border border-slate-700 bg-slate-900/95 p-4 shadow-2xl backdrop-blur-md sm:bottom-24 sm:left-6 sm:w-80"
  role="dialog"
  aria-label="إعدادات القراءة"
>
  <div class="mb-3 flex items-center justify-between">
    <h2 class="text-sm font-bold text-white">إعدادات القراءة</h2>
    <button id="rsClose" type="button" aria-label="إغلاق" class="rounded p-1 text-slate-400 transition hover:bg-slate-800 hover:text-white">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Font size -->
  <div class="mb-4">
    <label class="mb-2 block text-xs font-semibold text-slate-300">حجم الخط</label>
    <div class="flex items-center gap-2">
      <button id="rsFontDown" type="button" class="h-9 w-9 rounded-lg border border-slate-700 bg-slate-800 text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400" aria-label="تصغير الخط">
        <svg class="mx-auto h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
      </button>
      <div id="rsFontLabel" class="flex-1 rounded-lg bg-slate-800/60 px-3 py-2 text-center text-sm font-semibold text-white">100%</div>
      <button id="rsFontUp" type="button" class="h-9 w-9 rounded-lg border border-slate-700 bg-slate-800 text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400" aria-label="تكبير الخط">
        <svg class="mx-auto h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
      </button>
    </div>
  </div>

  <!-- Line height -->
  <div class="mb-4">
    <label class="mb-2 block text-xs font-semibold text-slate-300">تباعد الأسطر</label>
    <div class="grid grid-cols-3 gap-2">
      <button type="button" data-line="0.85" class="rs-line rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-xs text-slate-300 transition hover:border-emerald-500/50">ضيّق</button>
      <button type="button" data-line="1" class="rs-line rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-xs text-slate-300 transition hover:border-emerald-500/50">متوسط</button>
      <button type="button" data-line="1.2" class="rs-line rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-xs text-slate-300 transition hover:border-emerald-500/50">واسع</button>
    </div>
  </div>

  <!-- Theme -->
  <div class="mb-1">
    <label class="mb-2 block text-xs font-semibold text-slate-300">المظهر</label>
    <div class="grid grid-cols-2 gap-2">
      <button type="button" data-theme="dark" class="rs-theme rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-xs text-slate-300 transition hover:border-emerald-500/50">داكن</button>
      <button type="button" data-theme="night" class="rs-theme rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-xs text-slate-300 transition hover:border-emerald-500/50">ليلي (أعمق)</button>
    </div>
  </div>

  <p class="mt-3 text-[10px] leading-relaxed text-slate-500">
    يتم حفظ إعداداتك محلياً في متصفحك فقط — بدون خوادم ولا تتبّع.
  </p>
</aside>

<script is:inline>
  (function () {
    const STORAGE_KEY = 'qr_reading_settings_v1';
    const defaults = { fontScale: 1, lineScale: 1, theme: 'dark' };
    function read() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...defaults };
        return { ...defaults, ...JSON.parse(raw) };
      } catch { return { ...defaults }; }
    }
    function write(s) {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch {}
    }
    function apply(s) {
      const root = document.documentElement;
      root.style.setProperty('--font-scale', String(s.fontScale));
      root.style.setProperty('--line-height-scale', String(s.lineScale));
      root.setAttribute('data-theme', s.theme);
      // Update panel UI if open
      const label = document.getElementById('rsFontLabel');
      if (label) label.textContent = Math.round(s.fontScale * 100) + '%';
      document.querySelectorAll('.rs-line').forEach((b) => {
        b.classList.toggle('rs-active', Number(b.dataset.line) === s.lineScale);
      });
      document.querySelectorAll('.rs-theme').forEach((b) => {
        b.classList.toggle('rs-active', b.dataset.theme === s.theme);
      });
    }
    // Restore immediately (run before first paint of settings panel open)
    let state = read();
    apply(state);

    function setOpen(open) {
      const panel = document.getElementById('rsPanel');
      const btn = document.getElementById('rsOpen');
      if (!panel || !btn) return;
      panel.classList.toggle('hidden', !open);
      btn.setAttribute('aria-expanded', String(open));
    }

    document.getElementById('rsOpen')?.addEventListener('click', () => {
      const panel = document.getElementById('rsPanel');
      setOpen(panel?.classList.contains('hidden') ?? true);
    });
    document.getElementById('rsClose')?.addEventListener('click', () => setOpen(false));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });

    document.getElementById('rsFontDown')?.addEventListener('click', () => {
      state.fontScale = Math.max(0.7, +(state.fontScale - 0.1).toFixed(2));
      apply(state); write(state);
    });
    document.getElementById('rsFontUp')?.addEventListener('click', () => {
      state.fontScale = Math.min(1.6, +(state.fontScale + 0.1).toFixed(2));
      apply(state); write(state);
    });
    document.querySelectorAll('.rs-line').forEach((b) => {
      b.addEventListener('click', () => {
        state.lineScale = Number(b.dataset.line);
        apply(state); write(state);
      });
    });
    document.querySelectorAll('.rs-theme').forEach((b) => {
      b.addEventListener('click', () => {
        state.theme = b.dataset.theme;
        apply(state); write(state);
      });
    });
  })();
</script>

<style>
  .rs-active {
    border-color: rgb(16 185 129) !important;
    background: rgba(16, 185, 129, 0.1) !important;
    color: rgb(110 231 183) !important;
  }
  /* Night theme: deeper blacks, reduced blue glow, warmer text */
  html[data-theme="night"] body { background: #000 !important; }
  html[data-theme="night"] .quran-text { color: #e6dcc8 !important; }
</style>
