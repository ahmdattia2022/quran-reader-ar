---
/**
 * Modal for signing in via email magic link, and signing out when already
 * authenticated. Opened by dispatching window event `qr:open-auth` from
 * anywhere in the app (or by clicking #auth-trigger).
 *
 * If Supabase isn't configured, the modal silently disables itself so the
 * site degrades to local-only.
 */
---
<!--
  Trigger lives above the PWA install button on BOTH mobile and desktop
  (both are anchored bottom-right). Without this offset the two controls
  stack on top of each other on phones.
-->
<button
  id="auth-trigger"
  type="button"
  class="fixed bottom-[4.5rem] right-4 z-30 hidden h-11 items-center gap-2 rounded-full border border-slate-700 bg-slate-900/85 px-4 text-xs font-semibold text-slate-200 shadow-lg backdrop-blur-md transition hover:border-emerald-500 hover:text-emerald-400 sm:bottom-[4.75rem] sm:right-6"
  aria-label="تسجيل الدخول للمزامنة"
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
  </svg>
  <span id="auth-trigger-label">تسجيل الدخول</span>
</button>

<div
  id="auth-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/80 px-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="auth-title"
>
  <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-6 shadow-2xl">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h2 id="auth-title" class="text-lg font-bold text-white">المزامنة عبر الأجهزة</h2>
        <p class="mt-1 text-sm text-slate-400">اختياري · بريد إلكتروني فقط · بدون كلمة مرور</p>
      </div>
      <button id="auth-close" type="button" class="rounded p-1 text-slate-400 transition hover:bg-slate-800 hover:text-white" aria-label="إغلاق">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Signed-out state -->
    <div id="auth-signed-out" class="mt-5">
      <p class="text-sm leading-relaxed text-slate-300">
        سجّل الدخول لمزامنة إشاراتك وإعداداتك بين هاتفك وحاسوبك.
        سنرسل لك <strong class="text-white">رابط دخول سحري</strong> عبر البريد — بدون كلمة مرور.
      </p>

      <form id="auth-form" class="mt-5 space-y-3">
        <label class="block">
          <span class="mb-1 block text-xs font-semibold text-slate-300">البريد الإلكتروني</span>
          <input
            id="auth-email"
            type="email"
            required
            dir="ltr"
            placeholder="name@example.com"
            class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm text-white placeholder:text-slate-500 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30"
          />
        </label>
        <button
          type="submit"
          id="auth-submit"
          class="w-full rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-emerald-400 disabled:cursor-not-allowed disabled:bg-slate-700 disabled:text-slate-400"
        >
          أرسل رابط الدخول
        </button>
        <p id="auth-error" class="hidden rounded-lg border border-red-500/40 bg-red-950/40 px-3 py-2 text-xs text-red-300"></p>
        <p id="auth-success" class="hidden rounded-lg border border-emerald-500/40 bg-emerald-950/30 px-3 py-2 text-xs text-emerald-300">
          تم إرسال رابط الدخول. افتح بريدك الإلكتروني واضغط على الرابط للدخول.
        </p>
      </form>

      <ul class="mt-5 space-y-2 text-xs leading-relaxed text-slate-400">
        <li>✔ مزامنة تلقائية بين أجهزتك</li>
        <li>✔ نخزّن فقط بريدك وبياناتك (إشارات، إعدادات، موقع الصلاة)</li>
        <li>✔ يمكنك حذف حسابك وكل بياناتك بضغطة زر</li>
        <li>✔ بدون إعلانات، بدون تتبّع، بدون مشاركة بيانات مع أي جهة</li>
      </ul>
    </div>

    <!-- Signed-in state -->
    <div id="auth-signed-in" class="mt-5 hidden">
      <div class="rounded-lg border border-emerald-500/40 bg-emerald-500/5 p-4">
        <p class="text-xs uppercase tracking-wider text-emerald-300">مُسجَّل الدخول</p>
        <p id="auth-email-label" class="mt-1 truncate text-sm font-semibold text-white" dir="ltr">—</p>
        <p class="mt-2 text-xs text-slate-400">
          تتم مزامنة إشاراتك وإعداداتك تلقائياً.
        </p>
      </div>

      <div class="mt-4 grid gap-2">
        <button id="auth-signout" type="button" class="rounded-lg border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm text-slate-200 transition hover:border-slate-600">
          تسجيل الخروج
        </button>
        <button id="auth-delete" type="button" class="rounded-lg border border-red-500/40 bg-red-950/30 px-4 py-2.5 text-sm text-red-300 transition hover:bg-red-950/50">
          حذف بياناتي من الخادم
        </button>
        <p class="text-[10px] leading-relaxed text-slate-500">
          يحذف هذا إشاراتك وإعداداتك من الخادم ويسجّل خروجك. حساب البريد يبقى (لإعادة الدخول في أي وقت).
        </p>
      </div>
    </div>

    <p class="mt-5 text-[10px] leading-relaxed text-slate-500">
      بيانات الجلسة تُحفظ في متصفحك. يمكنك مراجعة
      <a href="/privacy/" class="text-emerald-400 underline hover:text-emerald-300">سياسة الخصوصية</a>
      لتفاصيل ما نحفظه.
    </p>
  </div>
</div>

<script>
  import { getSupabase, isConfigured } from '../lib/supabase';
  import { signInWithMagicLink, signOut, deleteAccountData, getCurrentUserEmail } from '../lib/sync';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const trigger = $('auth-trigger');
  const triggerLabel = $('auth-trigger-label');
  const modal = $('auth-modal');
  const closeBtn = $('auth-close');
  const signedOut = $('auth-signed-out');
  const signedIn = $('auth-signed-in');
  const emailLabel = $('auth-email-label');
  const form = $<HTMLFormElement>('auth-form');
  const emailInput = $<HTMLInputElement>('auth-email');
  const submit = $<HTMLButtonElement>('auth-submit');
  const errBox = $('auth-error');
  const successBox = $('auth-success');
  const signoutBtn = $('auth-signout');
  const deleteBtn = $('auth-delete');

  // Hide the trigger entirely if Supabase isn't configured
  if (!isConfigured()) {
    trigger.remove();
    modal.remove();
  } else {
    trigger.classList.remove('hidden');
    trigger.classList.add('flex');

    function openModal() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      emailInput.focus();
    }
    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      errBox.classList.add('hidden');
      successBox.classList.add('hidden');
    }

    async function refreshState() {
      const email = await getCurrentUserEmail();
      if (email) {
        triggerLabel.textContent = email.split('@')[0];
        signedOut.classList.add('hidden');
        signedIn.classList.remove('hidden');
        emailLabel.textContent = email;
      } else {
        triggerLabel.textContent = 'تسجيل الدخول';
        signedOut.classList.remove('hidden');
        signedIn.classList.add('hidden');
      }
    }

    trigger.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal(); });

    window.addEventListener('qr:open-auth', openModal);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errBox.classList.add('hidden');
      successBox.classList.add('hidden');
      submit.disabled = true;
      submit.textContent = 'جارٍ الإرسال…';
      const res = await signInWithMagicLink(emailInput.value.trim());
      submit.disabled = false;
      submit.textContent = 'أرسل رابط الدخول';
      if (res.ok) {
        successBox.classList.remove('hidden');
      } else {
        errBox.textContent = res.error || 'تعذّر الإرسال';
        errBox.classList.remove('hidden');
      }
    });

    signoutBtn.addEventListener('click', async () => {
      await signOut();
      await refreshState();
      closeModal();
    });

    deleteBtn.addEventListener('click', async () => {
      if (!confirm('سيتم حذف إشاراتك وإعداداتك من الخادم نهائياً وتسجيل خروجك. متأكد؟')) return;
      const res = await deleteAccountData();
      if (res.ok) {
        await refreshState();
        closeModal();
      } else {
        errBox.textContent = res.error || 'تعذّر الحذف';
        errBox.classList.remove('hidden');
      }
    });

    // Listen to auth state changes
    const sb = getSupabase();
    if (sb) sb.auth.onAuthStateChange(() => { refreshState(); });
    refreshState();
  }
</script>
