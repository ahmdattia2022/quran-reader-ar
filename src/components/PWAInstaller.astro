---
/**
 * Registers the service worker and shows a subtle "install app" button
 * when the browser fires beforeinstallprompt. The button also provides
 * iOS instructions (iOS Safari doesn't fire the event).
 */
---
<button
  id="pwa-install"
  type="button"
  class="fixed bottom-4 right-4 z-30 hidden items-center gap-2 rounded-full border border-emerald-500/50 bg-emerald-500/15 px-4 py-2.5 text-xs font-semibold text-emerald-200 shadow-lg backdrop-blur-md transition hover:bg-emerald-500/25 sm:bottom-6 sm:right-6"
  aria-label="تثبيت التطبيق"
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
    <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
  </svg>
  <span>تثبيت التطبيق</span>
</button>

<div id="pwa-ios-tip" class="fixed bottom-4 right-4 z-30 hidden max-w-xs rounded-xl border border-slate-700 bg-slate-900/95 p-4 text-xs text-slate-200 shadow-xl backdrop-blur-md sm:bottom-6 sm:right-6">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="font-bold text-white">تثبيت التطبيق على iPhone</p>
      <p class="mt-1 leading-relaxed text-slate-400">
        اضغط زر المشاركة <span class="mx-1 inline-block">⇪</span> في سفاري، ثم اختر
        <strong class="text-emerald-300">«أضف إلى الشاشة الرئيسية»</strong>.
      </p>
    </div>
    <button id="pwa-ios-close" type="button" class="rounded p-0.5 text-slate-400 hover:text-white" aria-label="إغلاق">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    // Register SW (only in production / on https)
    if ('serviceWorker' in navigator && (location.protocol === 'https:' || location.hostname === 'localhost')) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }

    const btn = document.getElementById('pwa-install');
    const iosTip = document.getElementById('pwa-ios-tip');
    const iosClose = document.getElementById('pwa-ios-close');
    const DISMISSED_KEY = 'qr_pwa_dismissed_at';

    function isStandalone() {
      return window.matchMedia('(display-mode: standalone)').matches || navigator.standalone === true;
    }
    function wasDismissedRecently() {
      const t = Number(localStorage.getItem(DISMISSED_KEY) || 0);
      return t && Date.now() - t < 14 * 24 * 3600 * 1000; // 14 days
    }

    if (isStandalone()) return; // Already installed

    let deferred = null;
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferred = e;
      if (!wasDismissedRecently() && btn) {
        btn.classList.remove('hidden');
        btn.classList.add('flex');
      }
    });

    btn?.addEventListener('click', async () => {
      if (!deferred) return;
      deferred.prompt();
      const res = await deferred.userChoice.catch(() => ({ outcome: 'dismissed' }));
      if (res.outcome === 'dismissed') {
        localStorage.setItem(DISMISSED_KEY, String(Date.now()));
      }
      btn.classList.add('hidden');
      btn.classList.remove('flex');
      deferred = null;
    });

    // iOS fallback — show tip once after 8s if on Safari iOS
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !('MSStream' in window);
    const isSafari = /Safari/i.test(navigator.userAgent) && !/CriOS|FxiOS/i.test(navigator.userAgent);
    if (isIOS && isSafari && !wasDismissedRecently()) {
      setTimeout(() => {
        if (!isStandalone() && iosTip) {
          iosTip.classList.remove('hidden');
          iosTip.classList.add('block');
        }
      }, 8000);
    }

    iosClose?.addEventListener('click', () => {
      iosTip.classList.add('hidden');
      localStorage.setItem(DISMISSED_KEY, String(Date.now()));
    });
  })();
</script>
