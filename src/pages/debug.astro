---
import BaseLayout from '../layouts/BaseLayout.astro';

// Not indexed, not linked from navigation. Direct-URL-only debug page
// for viewing the in-browser log ring buffer.
---
<BaseLayout
  title="Debug — Quran Reader"
  description="Local log viewer"
  noindex={true}
>
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-white">Debug console</h1>
        <p class="mt-1 text-sm text-slate-400">
          Logs are stored in your browser (localStorage ring buffer, last 300). If Axiom is configured, they're also shipped upstream for remote monitoring (30-day retention).
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <button id="dbg-clear" type="button" class="rounded-lg border border-slate-700 bg-slate-800 px-3 py-1.5 text-xs text-slate-200 hover:border-emerald-500">Clear</button>
        <button id="dbg-export" type="button" class="rounded-lg border border-emerald-500/50 bg-emerald-500/10 px-3 py-1.5 text-xs text-emerald-300 hover:bg-emerald-500/20">Export JSON</button>
        <button id="dbg-copy" type="button" class="rounded-lg border border-slate-700 bg-slate-800 px-3 py-1.5 text-xs text-slate-200 hover:border-emerald-500">Copy to clipboard</button>
      </div>
    </div>

    <!-- Filters -->
    <div class="mb-4 grid gap-2 sm:grid-cols-[1fr_auto_auto]">
      <input
        id="dbg-search"
        type="search"
        placeholder="Filter message or meta..."
        class="rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-emerald-500 focus:outline-none"
      />
      <select id="dbg-level" class="rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white">
        <option value="">All levels</option>
        <option value="debug">Debug</option>
        <option value="info">Info</option>
        <option value="warn">Warn</option>
        <option value="error">Error</option>
      </select>
      <select id="dbg-area" class="rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white">
        <option value="">All areas</option>
      </select>
    </div>

    <!-- Status line -->
    <div class="mb-3 flex flex-wrap items-center gap-4 text-xs text-slate-500">
      <span>Total: <span id="dbg-total" class="text-slate-300">0</span></span>
      <span>Showing: <span id="dbg-shown" class="text-slate-300">0</span></span>
      <span>Remote sink: <span id="dbg-sink" class="text-slate-300">—</span></span>
      <label class="ml-auto inline-flex items-center gap-1.5">
        <input id="dbg-auto" type="checkbox" checked class="h-3.5 w-3.5 rounded border-slate-600 bg-slate-800" />
        <span>Auto-refresh on new logs</span>
      </label>
    </div>

    <div id="dbg-table" class="overflow-x-auto rounded-lg border border-slate-800">
      <table class="w-full min-w-[720px] text-left text-xs" dir="ltr">
        <thead class="bg-slate-900 text-slate-500 uppercase tracking-wider">
          <tr>
            <th class="whitespace-nowrap px-3 py-2 font-semibold">Time</th>
            <th class="whitespace-nowrap px-3 py-2 font-semibold">Level</th>
            <th class="whitespace-nowrap px-3 py-2 font-semibold">Area</th>
            <th class="px-3 py-2 font-semibold">Message</th>
            <th class="px-3 py-2 font-semibold">Meta</th>
          </tr>
        </thead>
        <tbody id="dbg-tbody" class="divide-y divide-slate-800 bg-slate-950/40 font-mono">
        </tbody>
      </table>
    </div>

    <div id="dbg-empty" class="hidden py-12 text-center text-slate-500">
      No log entries yet. Use the app (sign in, bookmark an ayah, etc.) and they'll appear here.
    </div>
  </section>

  <script>
    import { logger, type LogLevel, type LogEntry } from '../lib/logger';

    const tbody = document.getElementById('dbg-tbody')!;
    const empty = document.getElementById('dbg-empty')!;
    const totalEl = document.getElementById('dbg-total')!;
    const shownEl = document.getElementById('dbg-shown')!;
    const sinkEl = document.getElementById('dbg-sink')!;
    const searchInput = document.getElementById('dbg-search') as HTMLInputElement;
    const levelSelect = document.getElementById('dbg-level') as HTMLSelectElement;
    const areaSelect = document.getElementById('dbg-area') as HTMLSelectElement;
    const autoCb = document.getElementById('dbg-auto') as HTMLInputElement;

    sinkEl.textContent = logger.remoteEnabled() ? 'Axiom (active)' : 'localStorage only';
    sinkEl.className = logger.remoteEnabled() ? 'text-emerald-400' : 'text-amber-400';

    const LEVEL_COLORS: Record<LogLevel, string> = {
      debug: 'text-slate-500',
      info:  'text-sky-400',
      warn:  'text-amber-400',
      error: 'text-red-400',
    };

    function fmtTime(ts: number) {
      const d = new Date(ts);
      return d.toTimeString().slice(0, 8) + '.' + String(d.getMilliseconds()).padStart(3, '0');
    }

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
    }

    function render() {
      const all = logger.getAll();
      totalEl.textContent = String(all.length);

      // Populate area filter dynamically
      const areas = Array.from(new Set(all.map((e) => e.area))).sort();
      const currentArea = areaSelect.value;
      areaSelect.innerHTML = '<option value="">All areas</option>' +
        areas.map((a) => `<option value="${escapeHtml(a)}"${a === currentArea ? ' selected' : ''}>${escapeHtml(a)}</option>`).join('');

      const query = searchInput.value.toLowerCase().trim();
      const level = levelSelect.value;
      const area = areaSelect.value;

      const filtered = all.filter((e) => {
        if (level && e.level !== level) return false;
        if (area && e.area !== area) return false;
        if (query) {
          const hay = (e.msg + ' ' + JSON.stringify(e.meta || {})).toLowerCase();
          if (!hay.includes(query)) return false;
        }
        return true;
      }).reverse(); // newest first

      shownEl.textContent = String(filtered.length);

      if (filtered.length === 0) {
        tbody.innerHTML = '';
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');

      tbody.innerHTML = filtered.map((e) => {
        const metaStr = e.meta ? escapeHtml(JSON.stringify(e.meta)) : '';
        return `
          <tr class="hover:bg-slate-900/60">
            <td class="whitespace-nowrap px-3 py-1.5 text-slate-500">${fmtTime(e.ts)}</td>
            <td class="whitespace-nowrap px-3 py-1.5 font-semibold ${LEVEL_COLORS[e.level]}">${e.level.toUpperCase()}</td>
            <td class="whitespace-nowrap px-3 py-1.5 text-emerald-400">${escapeHtml(e.area)}</td>
            <td class="px-3 py-1.5 text-slate-200">${escapeHtml(e.msg)}</td>
            <td class="px-3 py-1.5 text-slate-500"><code class="whitespace-pre-wrap break-all">${metaStr}</code></td>
          </tr>`;
      }).join('');
    }

    render();

    searchInput.addEventListener('input', render);
    levelSelect.addEventListener('change', render);
    areaSelect.addEventListener('change', render);

    window.addEventListener('qr:log', () => {
      if (autoCb.checked) render();
    });

    document.getElementById('dbg-clear')!.addEventListener('click', () => {
      if (!confirm('Clear all local logs? This only clears your browser — remote logs (Axiom) are untouched.')) return;
      logger.clear();
      render();
    });

    document.getElementById('dbg-export')!.addEventListener('click', () => {
      const blob = new Blob([logger.export()], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `qr-logs-${new Date().toISOString().slice(0,19).replace(/:/g,'-')}.json`;
      a.click();
      URL.revokeObjectURL(url);
    });

    document.getElementById('dbg-copy')!.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(logger.export());
        const btn = document.getElementById('dbg-copy')!;
        const orig = btn.textContent;
        btn.textContent = 'Copied ✓';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      } catch {
        alert('Copy failed — use Export JSON instead.');
      }
    });

    // Generate a test log so the page isn't empty on first visit
    if (logger.getAll().length === 0) {
      logger.info('debug', 'debug page opened', { path: location.pathname });
      render();
    }
  </script>
</BaseLayout>
