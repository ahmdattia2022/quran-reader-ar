---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  allSurahs,
  surahIndex,
  arabicDigits,
  revelationTypeAr,
  shortSurahName,
  RECITERS,
  DEFAULT_RECITER,
  audioUrl,
} from '../../lib/quran.ts';

export async function getStaticPaths() {
  return allSurahs.map((s) => ({
    params: { number: String(s.number) },
    props: { surah: s },
  }));
}

const { surah } = Astro.props;
const shortName = shortSurahName(surah.name);
const prev = surah.number > 1 ? surahIndex[surah.number - 2] : null;
const next = surah.number < 114 ? surahIndex[surah.number] : null;

// The ayahs from the API include "بسم الله الرحمن الرحيم" prefix on the first ayah
// for most surahs. Surah 1 (Al-Fatihah) has it as ayah 1, surah 9 (At-Tawbah) has none.
// For display, we show basmala as a header (except for surah 1 and 9).
const showBasmalaHeader = surah.number !== 1 && surah.number !== 9;
const BASMALA = 'بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ';

// Strip leading basmala from the first ayah if present (for surahs other than 1 & 9)
function stripBasmala(text: string): string {
  const markers = ['بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ', 'بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ'];
  for (const m of markers) {
    if (text.startsWith(m)) return text.slice(m.length).trim();
  }
  return text;
}

const ayahs = surah.ayahs.map((a, i) => ({
  ...a,
  text: (i === 0 && showBasmalaHeader) ? stripBasmala(a.text) : a.text,
}));

// Pagination: only pre-render the first INITIAL_BATCH ayahs as HTML.
// The rest come from /surah-data/<n>.json on demand (mobile bandwidth).
const INITIAL_BATCH = 30;
const initialAyahs = ayahs.slice(0, INITIAL_BATCH);
const hasMore = ayahs.length > INITIAL_BATCH;

const title = `سورة ${shortName} مكتوبة كاملة - قراءة واستماع وتفسير | القرآن الكريم`;
const description = `سورة ${shortName} (${surah.englishName}) - ${revelationTypeAr(surah.revelationType)} - ${arabicDigits(surah.numberOfAyahs)} آية. اقرأ السورة كاملة بالرسم العثماني، مع التفسير الميسر والاستماع بأصوات كبار القراء.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `سورة ${shortName}`,
  alternativeHeadline: surah.englishName,
  inLanguage: 'ar',
  articleSection: 'القرآن الكريم',
  description,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  isPartOf: {
    '@type': 'Book',
    name: 'القرآن الكريم',
    inLanguage: 'ar',
  },
  about: {
    '@type': 'Thing',
    name: `سورة ${shortName}`,
  },
};
---
<BaseLayout
  title={title}
  description={description}
  ogType="article"
  jsonLd={jsonLd}
>
  <!-- Surah header -->
  <section class="relative border-b border-slate-800/60">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-emerald-950/30 via-slate-950 to-slate-950"></div>

    <div class="mx-auto max-w-4xl px-4 pt-10 pb-8 sm:px-6 md:pt-14">
      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-6 text-sm">
        <ol class="flex items-center gap-2 text-slate-400">
          <li><a href="/" class="transition hover:text-emerald-400">السور</a></li>
          <li class="text-slate-600">‹</li>
          <li class="text-slate-300">سورة {shortName}</li>
        </ol>
      </nav>

      <div class="text-center">
        <div class="inline-flex items-center gap-3 text-sm text-slate-400">
          <span class="rounded-full bg-slate-800 px-3 py-1">رقم {arabicDigits(surah.number)}</span>
          <span class={`rounded-full px-3 py-1 ${surah.revelationType === 'Meccan' ? 'bg-amber-500/10 text-amber-400' : 'bg-sky-500/10 text-sky-400'}`}>
            {revelationTypeAr(surah.revelationType)}
          </span>
          <span class="rounded-full bg-slate-800 px-3 py-1">{arabicDigits(surah.numberOfAyahs)} آية</span>
        </div>

        <h1 class="mt-5 text-4xl font-bold text-white md:text-6xl">
          سورة {shortName}
        </h1>
        <p class="mt-2 text-sm text-slate-500">
          {surah.englishName} · {surah.englishNameTranslation}
        </p>
      </div>

      <!-- Audio controls -->
      <div class="mt-8 rounded-2xl border border-slate-800 bg-slate-900/60 p-4 backdrop-blur">
        <div class="flex flex-wrap items-center gap-3">
          <button
            id="play-all-btn"
            type="button"
            class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-emerald-400"
          >
            <svg id="play-icon" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="pause-icon" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
            <span id="play-label">تشغيل السورة</span>
          </button>

          <div class="flex-1 min-w-[180px]">
            <label for="reciter-select" class="sr-only">اختر القارئ</label>
            <select
              id="reciter-select"
              class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30"
            >
              {RECITERS.map((r) => (
                <option value={r.id} selected={r.id === DEFAULT_RECITER}>{r.name}</option>
              ))}
            </select>
          </div>

          <button
            id="toggle-tafsir-btn"
            type="button"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400"
            aria-pressed="false"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            <span>إظهار التفسير</span>
          </button>

          <button
            id="toggle-range-btn"
            type="button"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400"
            aria-pressed="false"
            aria-expanded="false"
            aria-controls="range-panel"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 21V11l6-4v14M4 21l16-4M4 11l16-4"/>
            </svg>
            <span>نطاق التلاوة</span>
          </button>

          <button
            id="toggle-memo-btn"
            type="button"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400"
            aria-pressed="false"
            title="إخفاء نص الآيات للمراجعة والحفظ"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
            <span>وضع الحفظ</span>
          </button>
        </div>

        <!-- Range / loop / speed panel -->
        <div id="range-panel" class="mt-4 hidden border-t border-slate-800 pt-4">
          <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-4">
            <div>
              <label for="range-from" class="mb-1 block text-xs font-semibold uppercase tracking-wider text-slate-400">من الآية</label>
              <input id="range-from" type="number" min="1" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30" />
            </div>
            <div>
              <label for="range-to" class="mb-1 block text-xs font-semibold uppercase tracking-wider text-slate-400">إلى الآية</label>
              <input id="range-to" type="number" min="1" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30" />
            </div>
            <div>
              <label for="range-loop" class="mb-1 block text-xs font-semibold uppercase tracking-wider text-slate-400">التكرار</label>
              <select id="range-loop" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30">
                <option value="1">مرة واحدة</option>
                <option value="2">٢ مرات</option>
                <option value="3">٣ مرات</option>
                <option value="5">٥ مرات</option>
                <option value="10">١٠ مرات</option>
                <option value="0">∞ متواصل</option>
              </select>
            </div>
            <div>
              <label for="range-speed" class="mb-1 block text-xs font-semibold uppercase tracking-wider text-slate-400">السرعة</label>
              <select id="range-speed" class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30">
                <option value="0.5">٠٫٥×</option>
                <option value="0.75">٠٫٧٥×</option>
                <option value="1" selected>١×</option>
                <option value="1.25">١٫٢٥×</option>
                <option value="1.5">١٫٥×</option>
                <option value="2">٢×</option>
              </select>
            </div>
          </div>
          <p id="range-hint" class="mt-3 text-xs text-slate-500">
            اضبط النطاق والتكرار ثم اضغط «تشغيل السورة» للبدء. النطاق الافتراضي هو السورة كاملة بدون تكرار.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ayahs -->
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6 md:py-12">
    {showBasmalaHeader && (
      <div class="quran-text mb-10 text-center text-emerald-300" set:html={BASMALA}></div>
    )}

    <div id="ayahs" class="space-y-5">
      {initialAyahs.map((a) => (
        <article
          class="ayah-card rounded-2xl border border-slate-800 bg-slate-900/30 p-5 md:p-6"
          data-ayah={a.numberInSurah}
          data-ayah-global={a.numberInQuran}
          id={`ayah-${a.numberInSurah}`}
        >
          <!-- Ayah header -->
          <div class="mb-4 flex items-center justify-between gap-3">
            <div class="flex items-center gap-2">
              <span class="flex h-9 w-9 items-center justify-center rounded-full border border-emerald-500/40 bg-emerald-500/10 text-sm font-bold text-emerald-400 arabic-num">
                {arabicDigits(a.numberInSurah)}
              </span>
              <span class="text-xs text-slate-500">
                جزء {arabicDigits(a.juz)} · صفحة {arabicDigits(a.page)}
              </span>
            </div>

            <div class="flex items-center gap-1">
              <button
                class="play-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-emerald-400"
                data-ayah-global={a.numberInQuran}
                data-ayah-local={a.numberInSurah}
                title="تشغيل هذه الآية"
                aria-label={`تشغيل الآية ${a.numberInSurah}`}
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </button>
              <button
                class="copy-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-emerald-400"
                data-ayah-text={a.text}
                data-ayah-local={a.numberInSurah}
                title="نسخ الآية"
                aria-label={`نسخ الآية ${a.numberInSurah}`}
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
              </button>
              <button
                class="share-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-sky-400"
                data-ayah-text={a.text}
                data-ayah-local={a.numberInSurah}
                title="مشاركة كصورة"
                aria-label={`مشاركة الآية ${a.numberInSurah} كصورة`}
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                </svg>
              </button>
              <button
                class="bookmark-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-amber-400"
                data-ayah-local={a.numberInSurah}
                title="إضافة إلى الإشارات"
                aria-label={`إشارة مرجعية للآية ${a.numberInSurah}`}
                aria-pressed="false"
              >
                <svg class="bookmark-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Ayah text -->
          <p class="quran-text text-slate-50">
            {a.text}
            <span class="ayah-number">﴿{arabicDigits(a.numberInSurah)}﴾</span>
          </p>

          <!-- Memorization-mode placeholder (shown only when mode is on and ayah not revealed) -->
          <button
            type="button"
            class="memo-placeholder hidden w-full rounded-lg border border-dashed border-emerald-500/30 bg-emerald-950/20 py-8 text-center text-sm text-emerald-300/80 transition hover:bg-emerald-950/30"
            aria-label={`إظهار الآية ${a.numberInSurah}`}
          >
            اضغط للإظهار · آية {arabicDigits(a.numberInSurah)}
          </button>

          <!-- Tafsir (hidden by default, toggled on) -->
          {a.tafsir && (
            <div class="tafsir-block mt-4 hidden rounded-lg border border-slate-800 bg-slate-950/50 p-4">
              <div class="mb-2 flex flex-wrap items-center gap-1">
                <button type="button" data-tafsir-edition="muyassar" class="tafsir-tab rounded-md border border-emerald-500 bg-emerald-500/10 px-2.5 py-1 text-xs font-semibold text-emerald-300" aria-selected="true">الميسر</button>
                <button type="button" data-tafsir-edition="jalalayn" class="tafsir-tab rounded-md border border-slate-700 bg-slate-800/40 px-2.5 py-1 text-xs text-slate-300 transition hover:border-emerald-500/60 hover:text-emerald-300" aria-selected="false">الجلالين</button>
                <button type="button" data-tafsir-edition="baghawi" class="tafsir-tab rounded-md border border-slate-700 bg-slate-800/40 px-2.5 py-1 text-xs text-slate-300 transition hover:border-emerald-500/60 hover:text-emerald-300" aria-selected="false">البغوي</button>
              </div>
              <p class="tafsir-text tafsir-text-muyassar" data-tafsir-source="muyassar">{a.tafsir}</p>
              <p class="tafsir-text tafsir-text-jalalayn hidden text-slate-300" data-tafsir-source="jalalayn" data-ayah-global={a.numberInQuran}></p>
              <p class="tafsir-text tafsir-text-baghawi hidden text-slate-300" data-tafsir-source="baghawi" data-ayah-global={a.numberInQuran}></p>
            </div>
          )}
        </article>
      ))}
    </div>

    <!-- Load-more (pagination) -->
    {hasMore && (
      <div id="load-more-wrap" class="mt-6 rounded-2xl border border-emerald-500/20 bg-slate-900/40 p-5 text-center">
        <p class="mb-2 text-sm text-slate-300">
          تم عرض <span id="lm-shown" class="font-bold text-emerald-400 arabic-num">{arabicDigits(INITIAL_BATCH)}</span>
          من <span class="font-bold text-white arabic-num">{arabicDigits(surah.numberOfAyahs)}</span> آية
        </p>
        <button
          id="load-more-btn"
          type="button"
          class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-emerald-400 disabled:cursor-wait disabled:opacity-70"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
          <span id="lm-label">عرض ٣٠ آية أخرى</span>
        </button>
        <p class="mt-2 text-[11px] text-slate-500">الإعدادات تنطبق على الآيات الجديدة تلقائياً</p>
      </div>
    )}

    <!-- Prev / Next nav -->
    <nav class="mt-12 grid gap-3 sm:grid-cols-2">
      {prev ? (
        <a href={`/surah/${prev.number}`} class="group flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/40 p-4 transition hover:border-emerald-500/60">
          <svg class="h-5 w-5 text-slate-500 transition group-hover:text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          <div class="flex-1 text-right">
            <p class="text-xs text-slate-500">السورة السابقة</p>
            <p class="font-semibold text-white">{shortSurahName(prev.name)}</p>
          </div>
        </a>
      ) : <div></div>}
      {next && (
        <a href={`/surah/${next.number}`} class="group flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/40 p-4 transition hover:border-emerald-500/60">
          <div class="flex-1">
            <p class="text-xs text-slate-500">السورة التالية</p>
            <p class="font-semibold text-white">{shortSurahName(next.name)}</p>
          </div>
          <svg class="h-5 w-5 rotate-180 text-slate-500 transition group-hover:text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </a>
      )}
    </nav>
  </section>

  <!-- Hidden audio element -->
  <audio id="player" preload="none"></audio>

  <!-- Toast notification for copy -->
  <div id="toast" class="fixed bottom-6 left-1/2 z-50 -translate-x-1/2 rounded-lg bg-slate-800 px-4 py-2.5 text-sm text-white opacity-0 shadow-xl ring-1 ring-emerald-500/30 transition-opacity duration-300 pointer-events-none"></div>

  <!-- Share modal (canvas-rendered PNG of the ayah) -->
  <div id="share-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/80 p-4 backdrop-blur-sm" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="share-title">
    <div class="w-full max-w-xl rounded-2xl border border-slate-800 bg-slate-900 p-5 shadow-2xl sm:p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <h3 id="share-title" class="text-lg font-bold text-white">مشاركة الآية كصورة</h3>
        <button id="share-close" type="button" class="rounded-lg p-1.5 text-slate-400 transition hover:bg-slate-800 hover:text-white" aria-label="إغلاق">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-950">
        <canvas id="share-canvas" width="1200" height="630" class="block w-full"></canvas>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <button id="share-download" type="button" class="inline-flex flex-1 items-center justify-center gap-2 rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-emerald-400">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          تنزيل الصورة
        </button>
        <button id="share-copy-img" type="button" class="inline-flex flex-1 items-center justify-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm font-semibold text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          نسخ كصورة
        </button>
        <button id="share-native" type="button" class="hidden inline-flex flex-1 items-center justify-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm font-semibold text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
          مشاركة
        </button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{
    totalAyahs: surah.numberOfAyahs,
    firstGlobal: ayahs[0].numberInQuran,
    surahName: shortName,
    surahNumber: surah.number,
    prevSurahHref: prev ? `/surah/${prev.number}` : null,
    nextSurahHref: next ? `/surah/${next.number}` : null,
  }}>
    (function () {
      const audio = document.getElementById('player');
      const playBtn = document.getElementById('play-all-btn');
      const playIcon = document.getElementById('play-icon');
      const pauseIcon = document.getElementById('pause-icon');
      const playLabel = document.getElementById('play-label');
      const reciterSelect = document.getElementById('reciter-select');
      const tafsirBtn = document.getElementById('toggle-tafsir-btn');
      const toast = document.getElementById('toast');
      const ayahCards = document.querySelectorAll('[data-ayah]');

      const RECITERS = {
        'ar.alafasy': 128,
        'ar.abdulbasitmurattal': 192,
        'ar.abdurrahmaansudais': 192,
        'ar.saoodshuraym': 64,
        'ar.mahermuaiqly': 128,
        'ar.minshawi': 128,
        'ar.husary': 128,
        'ar.hudhaify': 128,
        'ar.ibrahimakhbar': 32,
        'ar.muhammadayyoub': 128,
        'ar.muhammadjibreel': 128,
      };

      let currentReciter = localStorage.getItem('qr_reciter') || 'ar.alafasy';
      if (reciterSelect) reciterSelect.value = currentReciter;

      function audioUrlFor(globalNumber, reciterId) {
        const bitrate = RECITERS[reciterId] || 128;
        return `https://cdn.islamic.network/quran/audio/${bitrate}/${reciterId}/${globalNumber}.mp3`;
      }

      let currentAyahLocal = 0; // 1-based; 0 = not playing
      let playingAll = false;

      // ── Range / loop / speed panel state ──────────────────────────
      const rangeBtn = document.getElementById('toggle-range-btn');
      const rangePanel = document.getElementById('range-panel');
      const rangeFromEl = document.getElementById('range-from');
      const rangeToEl = document.getElementById('range-to');
      const rangeLoopEl = document.getElementById('range-loop');
      const rangeSpeedEl = document.getElementById('range-speed');
      const rangeHintEl = document.getElementById('range-hint');

      const rangeStorageKey = 'qr_range_v1';
      const defaultRange = { from: 1, to: totalAyahs, loop: 1, speed: 1 };
      let range = Object.assign({}, defaultRange);
      try {
        const saved = JSON.parse(localStorage.getItem(rangeStorageKey) || 'null');
        if (saved && typeof saved === 'object') {
          range.from = Math.max(1, Math.min(totalAyahs, Number(saved.from) || 1));
          range.to = Math.max(range.from, Math.min(totalAyahs, Number(saved.to) || totalAyahs));
          range.loop = saved.loop === 0 ? 0 : Math.max(1, Number(saved.loop) || 1);
          range.speed = [0.5, 0.75, 1, 1.25, 1.5, 2].includes(Number(saved.speed)) ? Number(saved.speed) : 1;
        }
      } catch {}

      rangeFromEl.min = '1'; rangeFromEl.max = String(totalAyahs); rangeFromEl.value = String(range.from);
      rangeToEl.min = '1'; rangeToEl.max = String(totalAyahs); rangeToEl.value = String(range.to);
      rangeLoopEl.value = String(range.loop);
      rangeSpeedEl.value = String(range.speed);

      let loopsRemaining = 0; // set when playback starts

      function saveRange() {
        try { localStorage.setItem(rangeStorageKey, JSON.stringify(range)); } catch {}
      }
      function updateRangeHint() {
        const isDefault = range.from === 1 && range.to === totalAyahs && range.loop === 1 && range.speed === 1;
        rangeHintEl.textContent = isDefault
          ? 'اضبط النطاق والتكرار ثم اضغط «تشغيل السورة» للبدء. النطاق الافتراضي هو السورة كاملة بدون تكرار.'
          : `سيتم تشغيل الآيات ${range.from}–${range.to} · ${range.loop === 0 ? 'تكرار متواصل' : range.loop + ' مرة'} · ${range.speed}×`;
      }
      updateRangeHint();

      rangeBtn.addEventListener('click', () => {
        const open = rangePanel.classList.toggle('hidden') === false;
        rangeBtn.setAttribute('aria-expanded', String(open));
        rangeBtn.setAttribute('aria-pressed', String(open));
        if (open) {
          rangeBtn.classList.add('border-emerald-500', 'text-emerald-400');
        } else {
          rangeBtn.classList.remove('border-emerald-500', 'text-emerald-400');
        }
      });

      rangeFromEl.addEventListener('change', () => {
        const v = Math.max(1, Math.min(totalAyahs, Number(rangeFromEl.value) || 1));
        range.from = v;
        if (range.to < v) { range.to = v; rangeToEl.value = String(v); }
        rangeFromEl.value = String(v);
        saveRange(); updateRangeHint();
      });
      rangeToEl.addEventListener('change', () => {
        const v = Math.max(range.from, Math.min(totalAyahs, Number(rangeToEl.value) || totalAyahs));
        range.to = v;
        rangeToEl.value = String(v);
        saveRange(); updateRangeHint();
      });
      rangeLoopEl.addEventListener('change', () => {
        range.loop = Number(rangeLoopEl.value);
        saveRange(); updateRangeHint();
      });
      rangeSpeedEl.addEventListener('change', () => {
        range.speed = Number(rangeSpeedEl.value) || 1;
        if (audio.playbackRate !== range.speed) audio.playbackRate = range.speed;
        saveRange(); updateRangeHint();
      });

      function setPlayingUI(isPlaying) {
        if (isPlaying) {
          playIcon.classList.add('hidden');
          pauseIcon.classList.remove('hidden');
          playLabel.textContent = 'إيقاف';
        } else {
          playIcon.classList.remove('hidden');
          pauseIcon.classList.add('hidden');
          playLabel.textContent = 'تشغيل السورة';
        }
      }

      function highlightAyah(local) {
        document.querySelectorAll('.ayah-active').forEach((el) => el.classList.remove('ayah-active'));
        if (local < 1) return;
        const el = document.getElementById(`ayah-${local}`);
        if (!el) return;
        el.classList.add('ayah-active');
        // Only auto-scroll if the ayah isn't already visible — lets the
        // user scroll ahead while audio plays without getting yanked back.
        const rect = el.getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;
        const fullyVisible = rect.top >= 0 && rect.bottom <= vh;
        if (!fullyVisible) {
          el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      function playAyah(local) {
        currentAyahLocal = local;
        const globalNum = firstGlobal + (local - 1);
        audio.src = audioUrlFor(globalNum, currentReciter);
        audio.playbackRate = range.speed;
        audio.play().catch((e) => console.warn('Audio play failed:', e));
        // Optimistic highlight (snappy feedback) — the `playing` event
        // listener below re-highlights once audio actually starts, to
        // keep visual + audio in sync on slow networks.
        highlightAyah(local);
        setPlayingUI(true);
        // Persist last-played position
        const surahMatch = location.pathname.match(/\/surah\/(\d+)/);
        if (surahMatch) {
          localStorage.setItem('qr_last_read', JSON.stringify({ surah: Number(surahMatch[1]), ayah: local }));
        }
      }

      // Authoritative sync: when audio actually starts producing sound,
      // confirm the highlight on the current ayah. Guards against cases
      // where audio src changed but UI didn't catch up.
      audio.addEventListener('playing', () => {
        if (currentAyahLocal > 0) highlightAyah(currentAyahLocal);
      });

      // Exposed later by the pagination block so 'ended' can lazy-load
      // the next batch before advancing past the last rendered ayah.
      let loadMoreAyahs = null;

      async function ensureAyahRendered(local) {
        if (document.getElementById(`ayah-${local}`)) return true;
        if (!loadMoreAyahs) return false;
        // Load batches until we reach the requested ayah (bounded)
        for (let i = 0; i < 20; i++) {
          try { await loadMoreAyahs(); } catch { return false; }
          if (document.getElementById(`ayah-${local}`)) return true;
        }
        return false;
      }

      audio.addEventListener('ended', async () => {
        if (!playingAll) {
          setPlayingUI(false);
          highlightAyah(0);
          return;
        }
        // Advance within the range, then handle loop
        if (currentAyahLocal < range.to) {
          const next = currentAyahLocal + 1;
          await ensureAyahRendered(next);
          playAyah(next);
          return;
        }
        // End of range reached — loop?
        if (loopsRemaining === 0 /* infinite */) {
          await ensureAyahRendered(range.from);
          playAyah(range.from);
          return;
        }
        if (loopsRemaining > 1) {
          loopsRemaining -= 1;
          await ensureAyahRendered(range.from);
          playAyah(range.from);
          return;
        }
        // Done
        playingAll = false;
        setPlayingUI(false);
        highlightAyah(0);
      });

      audio.addEventListener('pause', () => {
        if (audio.ended) return;
        setPlayingUI(false);
      });

      audio.addEventListener('play', () => setPlayingUI(true));

      // ── Screen Wake Lock (keep screen on while reciting) ────────────
      let wakeLock = null;
      async function acquireWakeLock() {
        try {
          if ('wakeLock' in navigator && !wakeLock) {
            wakeLock = await navigator.wakeLock.request('screen');
            wakeLock.addEventListener('release', () => { wakeLock = null; });
          }
        } catch (e) { /* permission denied or unsupported — no-op */ }
      }
      function releaseWakeLock() {
        if (wakeLock) { try { wakeLock.release(); } catch {} wakeLock = null; }
      }
      audio.addEventListener('play', acquireWakeLock);
      audio.addEventListener('pause', releaseWakeLock);
      audio.addEventListener('ended', releaseWakeLock);
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible' && audio && !audio.paused && !audio.ended) {
          // Browsers auto-release when hidden; re-acquire on return
          acquireWakeLock();
        }
      });

      playBtn.addEventListener('click', () => {
        if (!audio.paused && !audio.ended) {
          playingAll = false;
          audio.pause();
          return;
        }
        if (audio.src && audio.currentTime > 0 && !audio.ended) {
          playingAll = true;
          audio.play();
          return;
        }
        playingAll = true;
        // Snap range to valid bounds, then start
        range.from = Math.max(1, Math.min(totalAyahs, range.from));
        range.to = Math.max(range.from, Math.min(totalAyahs, range.to));
        loopsRemaining = range.loop; // 0 = infinite; N = total plays
        playAyah(range.from);
      });

      reciterSelect.addEventListener('change', (e) => {
        currentReciter = e.target.value;
        localStorage.setItem('qr_reciter', currentReciter);
        if (!audio.paused && currentAyahLocal > 0) {
          const wasPlayingAll = playingAll;
          playAyah(currentAyahLocal);
          playingAll = wasPlayingAll;
        }
      });

      // showToast used throughout (copy, share, bookmark, pagination)
      function showToast(msg) {
        toast.textContent = msg;
        toast.style.opacity = '1';
        clearTimeout(toast._timer);
        toast._timer = setTimeout(() => { toast.style.opacity = '0'; }, 1800);
      }

      // Per-card wiring happens in wireAyahCards() at the bottom of this
      // IIFE, called for both the initial 30 ayahs AND any new batch
      // appended by the pagination loader.

      // URL-as-state: if ?ayah=N is present, scroll + highlight that ayah.
      // Deferred via setTimeout so the pagination loader (below) is wired
      // before we try to load batches to reach the target.
      setTimeout(async function handleTargetAyah() {
        const params = new URLSearchParams(location.search);
        const target = Number(params.get('ayah'));
        if (!target || target < 1 || target > totalAyahs) return;
        await ensureAyahRendered(target);
        const el = document.getElementById(`ayah-${target}`);
        if (!el) return;
        requestAnimationFrame(() => {
          el.scrollIntoView({ behavior: 'smooth', block: 'center' });
          el.classList.add('ayah-active');
          setTimeout(() => el.classList.remove('ayah-active'), 3500);
        });
      }, 0);

      // Bookmarks (qr_bookmarks_v1 = [{s, a, ts}])
      const surahMatch = location.pathname.match(/\/surah\/(\d+)/);
      const surahNum = surahMatch ? Number(surahMatch[1]) : 0;

      function readBookmarks() {
        try { return JSON.parse(localStorage.getItem('qr_bookmarks_v1') || '[]'); } catch { return []; }
      }
      function writeBookmarks(arr) {
        try { localStorage.setItem('qr_bookmarks_v1', JSON.stringify(arr)); } catch {}
      }
      function isBookmarked(s, a, list) {
        return list.some((b) => b.s === s && b.a === a);
      }
      function paintBookmarkBtn(btn, on) {
        const icon = btn.querySelector('.bookmark-icon');
        if (!icon) return;
        if (on) {
          icon.setAttribute('fill', 'currentColor');
          btn.classList.add('text-amber-400');
          btn.classList.remove('text-slate-400');
          btn.setAttribute('aria-pressed', 'true');
          btn.title = 'إزالة من الإشارات';
        } else {
          icon.setAttribute('fill', 'none');
          btn.classList.remove('text-amber-400');
          btn.classList.add('text-slate-400');
          btn.setAttribute('aria-pressed', 'false');
          btn.title = 'إضافة إلى الإشارات';
        }
      }
      // Last-read tracking: a single shared IntersectionObserver. Exposed
      // here so wireAyahCards() can observe newly-paginated cards too.
      let lastReadIO = null;
      (function initLastReadObserver() {
        if (!('IntersectionObserver' in window) || !surahNum) return;
        let pendingLocal = 0;
        let pendingTimer = null;
        lastReadIO = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              const local = Number((e.target).dataset.ayah);
              if (!local) continue;
              pendingLocal = local;
              if (pendingTimer) clearTimeout(pendingTimer);
              pendingTimer = setTimeout(() => {
                try {
                  localStorage.setItem('qr_last_read', JSON.stringify({ surah: surahNum, ayah: pendingLocal, ts: Date.now() }));
                } catch {}
              }, 1500);
            }
          },
          { rootMargin: '-40% 0px -40% 0px', threshold: 0 },
        );
      })();

      // ── Share ayah as image ───────────────────────────────────────
      const shareModal = document.getElementById('share-modal');
      const shareCanvas = document.getElementById('share-canvas');
      const shareClose = document.getElementById('share-close');
      const shareDownload = document.getElementById('share-download');
      const shareCopyImg = document.getElementById('share-copy-img');
      const shareNative = document.getElementById('share-native');
      const arDigitsShare = (n) => String(n).replace(/[0-9]/g, (d) => '٠١٢٣٤٥٦٧٨٩'[+d]);

      if ('canShare' in navigator && typeof navigator.canShare === 'function') {
        // Only show native share on devices that actually support file sharing
        try {
          const probe = new File([new Blob([''], { type: 'image/png' })], 'probe.png', { type: 'image/png' });
          if (navigator.canShare({ files: [probe] })) shareNative.classList.remove('hidden');
        } catch {}
      }

      function openShareModal() {
        shareModal.classList.remove('hidden');
        shareModal.classList.add('flex');
        shareModal.setAttribute('aria-hidden', 'false');
      }
      function closeShareModal() {
        shareModal.classList.add('hidden');
        shareModal.classList.remove('flex');
        shareModal.setAttribute('aria-hidden', 'true');
      }
      shareClose.addEventListener('click', closeShareModal);
      shareModal.addEventListener('click', (e) => { if (e.target === shareModal) closeShareModal(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !shareModal.classList.contains('hidden')) closeShareModal();
      });

      // Wrap Arabic text to fit width on canvas
      function wrapArabicText(ctx, text, maxWidth) {
        const words = text.split(/\s+/);
        const lines = [];
        let line = '';
        for (const w of words) {
          const test = line ? line + ' ' + w : w;
          if (ctx.measureText(test).width <= maxWidth || !line) {
            line = test;
          } else {
            lines.push(line);
            line = w;
          }
        }
        if (line) lines.push(line);
        return lines;
      }

      async function renderShareCanvas(ayahText, ayahNumber) {
        const ctx = shareCanvas.getContext('2d');
        const W = shareCanvas.width;
        const H = shareCanvas.height;

        // Wait for Amiri to be loaded so the text renders in the right face
        try {
          if (document.fonts && document.fonts.load) {
            await document.fonts.load('700 56px Amiri');
            await document.fonts.load('600 28px "Noto Sans Arabic"');
          }
        } catch {}

        // Gradient background (emerald → slate)
        const grad = ctx.createLinearGradient(0, 0, W, H);
        grad.addColorStop(0, '#022c22');
        grad.addColorStop(0.55, '#0b1220');
        grad.addColorStop(1, '#020617');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);

        // Soft emerald glow
        const glow = ctx.createRadialGradient(W * 0.5, H * 0.1, 40, W * 0.5, H * 0.1, W * 0.9);
        glow.addColorStop(0, 'rgba(16, 185, 129, 0.30)');
        glow.addColorStop(1, 'rgba(16, 185, 129, 0)');
        ctx.fillStyle = glow;
        ctx.fillRect(0, 0, W, H);

        // Ornamental border (inner rounded frame)
        const pad = 48;
        ctx.strokeStyle = 'rgba(16, 185, 129, 0.35)';
        ctx.lineWidth = 2;
        const r = 24;
        ctx.beginPath();
        ctx.moveTo(pad + r, pad);
        ctx.lineTo(W - pad - r, pad);
        ctx.arcTo(W - pad, pad, W - pad, pad + r, r);
        ctx.lineTo(W - pad, H - pad - r);
        ctx.arcTo(W - pad, H - pad, W - pad - r, H - pad, r);
        ctx.lineTo(pad + r, H - pad);
        ctx.arcTo(pad, H - pad, pad, H - pad - r, r);
        ctx.lineTo(pad, pad + r);
        ctx.arcTo(pad, pad, pad + r, pad, r);
        ctx.closePath();
        ctx.stroke();

        // Ayah text (Amiri, centered)
        ctx.direction = 'rtl';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillStyle = '#f8fafc';

        const decorated = ayahText + ' ﴿' + arDigitsShare(ayahNumber) + '﴾';
        let fontSize = 60;
        ctx.font = `700 ${fontSize}px Amiri, "Amiri Quran", "Times New Roman", serif`;
        let lines = wrapArabicText(ctx, decorated, W - pad * 2 - 40);
        while (lines.length > 6 && fontSize > 34) {
          fontSize -= 4;
          ctx.font = `700 ${fontSize}px Amiri, "Amiri Quran", "Times New Roman", serif`;
          lines = wrapArabicText(ctx, decorated, W - pad * 2 - 40);
        }

        const lineHeight = fontSize * 1.55;
        const textBlockH = lines.length * lineHeight;
        const cy = H / 2 - textBlockH / 2 + lineHeight / 2 - 14;
        for (let i = 0; i < lines.length; i++) {
          ctx.fillText(lines[i], W / 2, cy + i * lineHeight);
        }

        // Surah label (bottom)
        ctx.font = '600 28px "Noto Sans Arabic", sans-serif';
        ctx.fillStyle = '#6ee7b7';
        ctx.fillText(`سورة ${surahName} — الآية ${arDigitsShare(ayahNumber)}`, W / 2, H - pad - 28);

        // Watermark (tiny, bottom)
        ctx.font = '500 16px "Noto Sans Arabic", sans-serif';
        ctx.fillStyle = 'rgba(148, 163, 184, 0.7)';
        ctx.fillText('quran-reader-ar.pages.dev', W / 2, H - pad + 4);
      }

      function canvasToBlob() {
        return new Promise((resolve) => shareCanvas.toBlob((b) => resolve(b), 'image/png'));
      }

      // .share-ayah-btn click listeners are attached via wireAyahCards()

      shareDownload.addEventListener('click', async () => {
        const blob = await canvasToBlob();
        if (!blob) { showToast('تعذّر إنشاء الصورة'); return; }
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `quran-${surahNumber}-ayah.png`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 4000);
        showToast('تم التنزيل');
      });

      shareCopyImg.addEventListener('click', async () => {
        try {
          const blob = await canvasToBlob();
          if (!blob) throw new Error('no blob');
          if (!('ClipboardItem' in window) || !navigator.clipboard?.write) {
            showToast('المتصفح لا يدعم نسخ الصور — استخدم التنزيل');
            return;
          }
          await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
          showToast('تم نسخ الصورة');
        } catch (e) {
          showToast('تعذّر النسخ — استخدم التنزيل');
        }
      });

      shareNative.addEventListener('click', async () => {
        try {
          const blob = await canvasToBlob();
          if (!blob) return;
          const file = new File([blob], `quran-${surahNumber}-ayah.png`, { type: 'image/png' });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({ files: [file], title: `سورة ${surahName}`, text: `من سورة ${surahName}` });
          }
        } catch {}
      });

      // Tafsir toggle
      let tafsirVisible = localStorage.getItem('qr_tafsir') === 'true';
      function applyTafsir() {
        document.querySelectorAll('.tafsir-block').forEach((el) => {
          el.classList.toggle('hidden', !tafsirVisible);
        });
        tafsirBtn.setAttribute('aria-pressed', String(tafsirVisible));
        tafsirBtn.querySelector('span').textContent = tafsirVisible ? 'إخفاء التفسير' : 'إظهار التفسير';
        if (tafsirVisible) {
          tafsirBtn.classList.add('border-emerald-500', 'text-emerald-400');
        } else {
          tafsirBtn.classList.remove('border-emerald-500', 'text-emerald-400');
        }
        if (tafsirVisible) loadActiveTafsirEdition();
      }
      applyTafsir();
      tafsirBtn.addEventListener('click', () => {
        tafsirVisible = !tafsirVisible;
        localStorage.setItem('qr_tafsir', String(tafsirVisible));
        applyTafsir();
      });

      // ── Tafsir editions (muyassar default, jalalayn + baghawi lazy) ──
      const TAFSIR_CACHE = {};
      let currentEdition = localStorage.getItem('qr_tafsir_edition') || 'muyassar';

      async function fetchEdition(edition) {
        if (edition === 'muyassar') return null;
        if (TAFSIR_CACHE[edition]) return TAFSIR_CACHE[edition];
        const url = '/tafsirs/ar.' + edition + '.json';
        const res = await fetch(url, { cache: 'force-cache' });
        if (!res.ok) throw new Error('fetch failed: ' + res.status);
        const data = await res.json();
        TAFSIR_CACHE[edition] = data;
        return data;
      }

      function paintTabs(edition) {
        document.querySelectorAll('.tafsir-tab').forEach((btn) => {
          const ed = btn.getAttribute('data-tafsir-edition');
          const active = ed === edition;
          btn.setAttribute('aria-selected', String(active));
          if (active) {
            btn.classList.remove('border-slate-700', 'bg-slate-800/40', 'text-slate-300');
            btn.classList.add('border-emerald-500', 'bg-emerald-500/10', 'text-emerald-300');
          } else {
            btn.classList.add('border-slate-700', 'bg-slate-800/40', 'text-slate-300');
            btn.classList.remove('border-emerald-500', 'bg-emerald-500/10', 'text-emerald-300');
          }
        });
        // Show/hide tafsir text blocks
        document.querySelectorAll('.tafsir-text').forEach((el) => {
          const src = el.getAttribute('data-tafsir-source');
          el.classList.toggle('hidden', src !== edition);
        });
      }

      async function loadActiveTafsirEdition() {
        paintTabs(currentEdition);
        if (currentEdition === 'muyassar') return;
        // Show a tiny loading hint in all target blocks first
        document.querySelectorAll('.tafsir-text-' + currentEdition).forEach((el) => {
          if (!el.textContent) el.textContent = '…';
        });
        try {
          const data = await fetchEdition(currentEdition);
          if (!data || !Array.isArray(data.texts)) return;
          document.querySelectorAll('.tafsir-text-' + currentEdition).forEach((el) => {
            const n = Number(el.getAttribute('data-ayah-global'));
            const t = data.texts[n - 1] || '';
            el.textContent = t || 'لا يوجد تفسير لهذه الآية في هذه الطبعة.';
          });
        } catch (e) {
          document.querySelectorAll('.tafsir-text-' + currentEdition).forEach((el) => {
            el.textContent = 'تعذّر تحميل التفسير. تحقق من الاتصال وحاول مجدداً.';
          });
        }
      }

      // .tafsir-tab click listeners are attached via wireAyahCards()

      if (tafsirVisible) loadActiveTafsirEdition();

      // ── Memorization mode ──────────────────────────────────────────
      const memoBtn = document.getElementById('toggle-memo-btn');
      const ayahsSection = document.getElementById('ayahs');
      let memoOn = localStorage.getItem('qr_memo') === 'true';

      function paintMemoBtn() {
        memoBtn.setAttribute('aria-pressed', String(memoOn));
        if (memoOn) {
          memoBtn.classList.add('border-emerald-500', 'text-emerald-400');
        } else {
          memoBtn.classList.remove('border-emerald-500', 'text-emerald-400');
        }
      }
      function applyMemo() {
        if (memoOn) {
          ayahsSection.classList.add('memo-mode');
        } else {
          ayahsSection.classList.remove('memo-mode');
          // Reset revealed state when turning off so next toggle starts fresh
          ayahsSection.querySelectorAll('.memo-revealed').forEach((el) => el.classList.remove('memo-revealed'));
        }
        paintMemoBtn();
      }

      memoBtn.addEventListener('click', () => {
        memoOn = !memoOn;
        localStorage.setItem('qr_memo', String(memoOn));
        applyMemo();
      });

      // .memo-placeholder click listeners are attached via wireAyahCards()

      applyMemo();

      // ── Page-level keyboard shortcuts ──────────────────────────────
      document.addEventListener('keydown', (e) => {
        const tag = (e.target && e.target.tagName || '').toLowerCase();
        if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
        if (e.ctrlKey || e.metaKey || e.altKey) return;
        // RTL: right arrow = "previous" in reading direction for Arabic; map accordingly
        if (e.key === 'ArrowRight' && prevSurahHref) { e.preventDefault(); location.href = prevSurahHref; return; }
        if (e.key === 'ArrowLeft' && nextSurahHref) { e.preventDefault(); location.href = nextSurahHref; return; }
        if (e.key === 'k' || e.key === 'K') { e.preventDefault(); playBtn.click(); return; }
        if (e.key === 't' || e.key === 'T') { e.preventDefault(); tafsirBtn.click(); return; }
        if (e.key === 'm' || e.key === 'M') { e.preventDefault(); memoBtn.click(); return; }
      });

      // ── Per-card wiring (idempotent via data-wired guard) ──────────
      // Works for both the initial SSR'd 30 ayahs and ones appended by
      // the pagination loader below.
      function wireAyahCards(scope) {
        scope = scope || document;
        // Play
        scope.querySelectorAll('.play-ayah-btn:not([data-wired])').forEach((btn) => {
          btn.setAttribute('data-wired', '1');
          btn.addEventListener('click', () => {
            const local = Number(btn.dataset.ayahLocal);
            playingAll = false;
            playAyah(local);
          });
        });
        // Copy
        scope.querySelectorAll('.copy-ayah-btn:not([data-wired])').forEach((btn) => {
          btn.setAttribute('data-wired', '1');
          btn.addEventListener('click', async () => {
            const text = btn.dataset.ayahText;
            const num = btn.dataset.ayahLocal;
            try {
              await navigator.clipboard.writeText(`${text} ﴿${num}﴾`);
              showToast('تم نسخ الآية');
            } catch { showToast('تعذّر النسخ'); }
          });
        });
        // Share
        scope.querySelectorAll('.share-ayah-btn:not([data-wired])').forEach((btn) => {
          btn.setAttribute('data-wired', '1');
          btn.addEventListener('click', async () => {
            const ayahText = btn.dataset.ayahText || '';
            const ayahNum = Number(btn.dataset.ayahLocal);
            openShareModal();
            await renderShareCanvas(ayahText, ayahNum);
          });
        });
        // Bookmark: paint + click
        const bmList = readBookmarks();
        scope.querySelectorAll('.bookmark-ayah-btn:not([data-wired])').forEach((btn) => {
          btn.setAttribute('data-wired', '1');
          const a = Number(btn.dataset.ayahLocal);
          paintBookmarkBtn(btn, isBookmarked(surahNum, a, bmList));
          btn.addEventListener('click', () => {
            const current = readBookmarks();
            const idx = current.findIndex((b) => b.s === surahNum && b.a === a);
            if (idx === -1) {
              current.push({ s: surahNum, a, ts: Date.now() });
              writeBookmarks(current);
              paintBookmarkBtn(btn, true);
              showToast('تمت إضافة الإشارة');
            } else {
              current.splice(idx, 1);
              writeBookmarks(current);
              paintBookmarkBtn(btn, false);
              showToast('تم حذف الإشارة');
            }
          });
        });
        // Memo placeholder
        scope.querySelectorAll('.memo-placeholder:not([data-wired])').forEach((p) => {
          p.setAttribute('data-wired', '1');
          p.addEventListener('click', () => {
            const card = p.closest('.ayah-card');
            if (card) card.classList.add('memo-revealed');
          });
        });
        // Tafsir tabs
        scope.querySelectorAll('.tafsir-tab:not([data-wired])').forEach((btn) => {
          btn.setAttribute('data-wired', '1');
          btn.addEventListener('click', () => {
            const ed = btn.getAttribute('data-tafsir-edition');
            if (!ed) return;
            currentEdition = ed;
            localStorage.setItem('qr_tafsir_edition', ed);
            loadActiveTafsirEdition();
          });
        });
        // IntersectionObserver for last-read
        if (lastReadIO) {
          scope.querySelectorAll('.ayah-card:not([data-observed])').forEach((card) => {
            card.setAttribute('data-observed', '1');
            lastReadIO.observe(card);
          });
        }
      }

      // Initial wire: all 30 SSR'd cards
      wireAyahCards();

      // ── Pagination: load next 30 ayahs from /surah-data/<n>.json ────
      const loadMoreBtn = document.getElementById('load-more-btn');
      const loadMoreWrap = document.getElementById('load-more-wrap');
      const lmShown = document.getElementById('lm-shown');
      const lmLabel = document.getElementById('lm-label');
      const BATCH_SIZE = 30;

      if (loadMoreBtn) {
        let loadedCount = document.querySelectorAll('#ayahs .ayah-card').length;
        let cachedData = null;

        async function fetchSurahData() {
          if (cachedData) return cachedData;
          const res = await fetch('/surah-data/' + surahNumber + '.json', { cache: 'force-cache' });
          if (!res.ok) throw new Error('fetch failed: ' + res.status);
          cachedData = await res.json();
          return cachedData;
        }

        const arDigitsP = (n) => String(n).replace(/[0-9]/g, (d) => '٠١٢٣٤٥٦٧٨٩'[+d]);
        function escHtml(s) {
          return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function renderAyahCardHTML(a) {
          const num = arDigitsP(a.n);
          const safeText = escHtml(a.t);
          const safeTafsir = escHtml(a.tf || '');
          const tafsirBlock = a.tf ? `
            <div class="tafsir-block mt-4 hidden rounded-lg border border-slate-800 bg-slate-950/50 p-4">
              <div class="mb-2 flex flex-wrap items-center gap-1">
                <button type="button" data-tafsir-edition="muyassar" class="tafsir-tab rounded-md border border-emerald-500 bg-emerald-500/10 px-2.5 py-1 text-xs font-semibold text-emerald-300" aria-selected="true">الميسر</button>
                <button type="button" data-tafsir-edition="jalalayn" class="tafsir-tab rounded-md border border-slate-700 bg-slate-800/40 px-2.5 py-1 text-xs text-slate-300 transition hover:border-emerald-500/60 hover:text-emerald-300" aria-selected="false">الجلالين</button>
                <button type="button" data-tafsir-edition="baghawi" class="tafsir-tab rounded-md border border-slate-700 bg-slate-800/40 px-2.5 py-1 text-xs text-slate-300 transition hover:border-emerald-500/60 hover:text-emerald-300" aria-selected="false">البغوي</button>
              </div>
              <p class="tafsir-text tafsir-text-muyassar" data-tafsir-source="muyassar">${safeTafsir}</p>
              <p class="tafsir-text tafsir-text-jalalayn hidden text-slate-300" data-tafsir-source="jalalayn" data-ayah-global="${a.g}"></p>
              <p class="tafsir-text tafsir-text-baghawi hidden text-slate-300" data-tafsir-source="baghawi" data-ayah-global="${a.g}"></p>
            </div>` : '';
          return `
            <article class="ayah-card rounded-2xl border border-slate-800 bg-slate-900/30 p-5 md:p-6" data-ayah="${a.n}" data-ayah-global="${a.g}" id="ayah-${a.n}">
              <div class="mb-4 flex items-center justify-between gap-3">
                <div class="flex items-center gap-2">
                  <span class="flex h-9 w-9 items-center justify-center rounded-full border border-emerald-500/40 bg-emerald-500/10 text-sm font-bold text-emerald-400 arabic-num">${num}</span>
                  <span class="text-xs text-slate-500">جزء ${arDigitsP(a.j)} · صفحة ${arDigitsP(a.p)}</span>
                </div>
                <div class="flex items-center gap-1">
                  <button class="play-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-emerald-400" data-ayah-global="${a.g}" data-ayah-local="${a.n}" title="تشغيل هذه الآية" aria-label="تشغيل الآية ${a.n}">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </button>
                  <button class="copy-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-emerald-400" data-ayah-text="${safeText}" data-ayah-local="${a.n}" title="نسخ الآية" aria-label="نسخ الآية ${a.n}">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  </button>
                  <button class="share-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-sky-400" data-ayah-text="${safeText}" data-ayah-local="${a.n}" title="مشاركة كصورة" aria-label="مشاركة الآية ${a.n} كصورة">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </button>
                  <button class="bookmark-ayah-btn rounded-lg p-2 text-slate-400 transition hover:bg-slate-800 hover:text-amber-400" data-ayah-local="${a.n}" title="إضافة إلى الإشارات" aria-label="إشارة مرجعية للآية ${a.n}" aria-pressed="false">
                    <svg class="bookmark-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                  </button>
                </div>
              </div>
              <p class="quran-text text-slate-50">${safeText} <span class="ayah-number">﴿${num}﴾</span></p>
              <button type="button" class="memo-placeholder hidden w-full rounded-lg border border-dashed border-emerald-500/30 bg-emerald-950/20 py-8 text-center text-sm text-emerald-300/80 transition hover:bg-emerald-950/30" aria-label="إظهار الآية ${a.n}">اضغط للإظهار · آية ${num}</button>
              ${tafsirBlock}
            </article>`;
        }

        async function loadMore() {
          try {
            loadMoreBtn.disabled = true;
            lmLabel.textContent = 'جارٍ التحميل…';
            const data = await fetchSurahData();
            const next = data.ayahs.slice(loadedCount, loadedCount + BATCH_SIZE);
            const wrap = document.createElement('div');
            wrap.innerHTML = next.map(renderAyahCardHTML).join('');
            // Unwrap children into #ayahs
            while (wrap.firstChild) ayahsSection.appendChild(wrap.firstChild);
            loadedCount += next.length;
            lmShown.textContent = arDigitsP(loadedCount);
            const remaining = data.ayahs.length - loadedCount;
            lmLabel.textContent = remaining > 0 ? `عرض ${arDigitsP(Math.min(BATCH_SIZE, remaining))} آية أخرى` : 'تم تحميل جميع الآيات';

            // Wire new cards + sync state
            wireAyahCards(ayahsSection);
            applyTafsir(); // re-apply visibility (no-op if tafsirVisible=false)
            if (currentEdition !== 'muyassar') loadActiveTafsirEdition();

            if (loadedCount >= data.ayahs.length) {
              loadMoreWrap.classList.add('hidden');
            }
            loadMoreBtn.disabled = false;
          } catch (e) {
            console.warn('load more failed:', e);
            lmLabel.textContent = 'تعذّر التحميل · حاول مجدداً';
            loadMoreBtn.disabled = false;
          }
        }

        loadMoreBtn.addEventListener('click', loadMore);
        // Exposed so the audio 'ended' handler + ?ayah= URL param can
        // trigger batched loading when advancing past the loaded set.
        loadMoreAyahs = loadMore;
      }
    })();
  </script>
</BaseLayout>
