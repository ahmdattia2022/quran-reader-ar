---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CITIES } from '../lib/cities.ts';
import { CALC_METHODS } from '../lib/prayer.ts';

const title = 'مواقيت الصلاة والقبلة والتاريخ الهجري | القرآن الكريم';
const description =
  'مواقيت الصلاة (الفجر، الظهر، العصر، المغرب، العشاء) محسوبة محلياً بدون خوادم، مع اتجاه القبلة والتاريخ الهجري. يعمل بدون إنترنت بعد التحميل الأول.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'مواقيت الصلاة والقبلة',
  inLanguage: 'ar',
  description,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
};
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6 md:py-14">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-6 text-sm">
      <ol class="flex items-center gap-2 text-slate-400">
        <li><a href="/" class="transition hover:text-emerald-400">الرئيسية</a></li>
        <li class="text-slate-600">‹</li>
        <li class="text-slate-300">المواقيت</li>
      </ol>
    </nav>

    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold text-white md:text-4xl">مواقيت الصلاة</h1>
      <p class="mt-2 text-sm text-slate-400">
        محسوبة محلياً على جهازك — بدون خوادم، بدون تتبّع، بدون إنترنت بعد التحميل الأول.
      </p>
    </div>

    <!-- Hijri + next-prayer hero -->
    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-emerald-500/30 bg-gradient-to-br from-emerald-950/60 to-slate-900/80 p-6">
        <p class="text-xs uppercase tracking-wider text-emerald-400">التاريخ الهجري</p>
        <p id="pt-hijri" class="mt-2 text-2xl font-bold text-white">—</p>
        <p id="pt-greg" class="mt-1 text-sm text-slate-400">—</p>
      </div>
      <div class="rounded-2xl border border-emerald-500/30 bg-gradient-to-br from-emerald-950/60 to-slate-900/80 p-6">
        <p class="text-xs uppercase tracking-wider text-emerald-400">الصلاة القادمة</p>
        <p id="pt-next-name" class="mt-2 text-2xl font-bold text-white">—</p>
        <p id="pt-next-in" class="mt-1 text-sm text-slate-400">—</p>
      </div>
    </div>

    <!-- Location picker -->
    <div class="mt-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
      <div class="flex flex-wrap items-center gap-2">
        <label class="text-sm font-semibold text-slate-200">الموقع:</label>
        <span id="pt-loc-label" class="text-sm text-emerald-400">— لم يُحدّد بعد —</span>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        <button
          id="pt-use-location"
          type="button"
          class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-emerald-400"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          تحديد موقعي تلقائياً
        </button>
        <div class="flex-1 min-w-[200px]">
          <select
            id="pt-city-select"
            class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30"
          >
            <option value="">— أو اختر مدينة —</option>
            {CITIES.map((c) => (
              <option value={`${c.lat},${c.lon}`} data-name-ar={c.nameAr} data-country={c.country}>
                {c.nameAr} · {c.country}
              </option>
            ))}
          </select>
        </div>
      </div>

      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div>
          <label class="mb-1 block text-xs font-semibold text-slate-400">طريقة الحساب</label>
          <select
            id="pt-method"
            class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none"
          >
            {CALC_METHODS.map((m) => (
              <option value={m.key}>{m.nameAr}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-1 block text-xs font-semibold text-slate-400">المذهب (للعصر)</label>
          <select
            id="pt-madhab"
            class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white focus:border-emerald-500 focus:outline-none"
          >
            <option value="Shafi">الشافعي / المالكي / الحنبلي</option>
            <option value="Hanafi">الحنفي</option>
          </select>
        </div>
      </div>

      <p id="pt-error" class="mt-3 hidden rounded-lg border border-red-500/30 bg-red-950/40 px-3 py-2 text-sm text-red-300"></p>
    </div>

    <!-- Prayer times grid -->
    <div id="pt-times" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <!-- Populated by script -->
    </div>

    <!-- Qibla section -->
    <div class="mt-10 rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
      <h2 class="mb-4 text-xl font-bold text-white">اتجاه القبلة</h2>

      <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
        <div class="relative mx-auto flex h-52 w-52 items-center justify-center">
          <!-- Compass face -->
          <div class="absolute inset-0 rounded-full border-2 border-slate-700 bg-slate-950/60"></div>
          <!-- N/S/E/W marks -->
          <span class="absolute top-1.5 text-xs font-bold text-slate-400">N</span>
          <span class="absolute bottom-1.5 text-xs font-bold text-slate-500">S</span>
          <span class="absolute left-1.5 text-xs font-bold text-slate-500">W</span>
          <span class="absolute right-1.5 text-xs font-bold text-slate-500">E</span>
          <!-- Kaaba arrow -->
          <div id="pt-compass-arrow" class="absolute inset-0 flex items-start justify-center transition-transform" style="transform: rotate(0deg)">
            <div class="mt-1 flex flex-col items-center">
              <div class="h-0 w-0 border-l-[12px] border-r-[12px] border-b-[22px] border-l-transparent border-r-transparent border-b-emerald-400"></div>
              <div class="-mt-1 h-20 w-1.5 bg-gradient-to-b from-emerald-400 to-emerald-600"></div>
            </div>
          </div>
          <!-- Center dot -->
          <div class="relative h-3 w-3 rounded-full bg-emerald-400 shadow-lg shadow-emerald-500/60"></div>
        </div>

        <div class="flex-1 space-y-3 text-sm">
          <div>
            <p class="text-xs uppercase tracking-wider text-slate-500">اتجاه القبلة من موقعك</p>
            <p id="pt-qibla-deg" class="mt-1 text-2xl font-bold text-white">— °</p>
          </div>
          <p class="text-slate-400">
            زاوية محسوبة من الشمال الجغرافي الحقيقي تجاه الكعبة المشرّفة (٢١.٤٢٢٥، ٣٩.٨٢٦٢).
          </p>
          <button
            id="pt-compass-toggle"
            type="button"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2 text-xs text-slate-200 transition hover:border-emerald-500 hover:text-emerald-400"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
            </svg>
            تفعيل البوصلة المباشرة (للهاتف)
          </button>
          <p id="pt-compass-note" class="text-xs text-slate-500">
            على الهاتف فقط — بعد التفعيل، وجّه الجهاز للأعلى وحرّكه حتى يشير السهم للأمام.
          </p>
        </div>
      </div>
    </div>

    <p class="mt-6 text-center text-xs text-slate-500">
      الحسابات تتم بالكامل على جهازك باستخدام مكتبة
      <a href="https://github.com/batoulapps/adhan-js" target="_blank" rel="noopener" class="text-emerald-400 underline hover:text-emerald-300">Adhan</a>
      المفتوحة المصدر. لا تُرسَل إحداثياتك إلى أي خادم.
    </p>
  </section>

  <script>
    import { PrayerTimes, Coordinates, CalculationMethod, Madhab } from 'adhan';
    import { qiblaBearing, hijriDateArabic, formatTime24, PRAYER_LABELS_AR } from '../lib/prayer.ts';

    const STORAGE_KEY = 'qr_prayer_settings_v1';
    const arDigits = (s: string | number) =>
      String(s).replace(/[0-9]/g, (d) => '٠١٢٣٤٥٦٧٨٩'[Number(d)]);

    interface Settings {
      lat: number | null;
      lon: number | null;
      label: string;
      method: string;
      madhab: 'Shafi' | 'Hanafi';
    }

    function load(): Settings {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) return JSON.parse(raw);
      } catch {}
      return { lat: null, lon: null, label: '', method: 'MuslimWorldLeague', madhab: 'Shafi' };
    }
    function save(s: Settings) {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch {}
    }

    const state = load();

    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const err = $('pt-error');
    const locLabel = $('pt-loc-label');
    const methodSel = $<HTMLSelectElement>('pt-method');
    const madhabSel = $<HTMLSelectElement>('pt-madhab');
    const citySel = $<HTMLSelectElement>('pt-city-select');

    methodSel.value = state.method;
    madhabSel.value = state.madhab;

    function showError(msg: string) {
      err.textContent = msg;
      err.classList.remove('hidden');
    }
    function clearError() { err.classList.add('hidden'); }

    function paramsFor(method: string, madhab: 'Shafi' | 'Hanafi') {
      const cm: any = CalculationMethod;
      const fn = cm[method] ?? cm.MuslimWorldLeague;
      const p = fn();
      p.madhab = madhab === 'Hanafi' ? Madhab.Hanafi : Madhab.Shafi;
      return p;
    }

    function compute() {
      // Hijri always shows
      $('pt-hijri').textContent = hijriDateArabic() || '';
      $('pt-greg').textContent = new Intl.DateTimeFormat('ar-EG', {
        weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
      }).format(new Date());

      if (state.lat == null || state.lon == null) {
        $('pt-times').innerHTML = `
          <div class="col-span-full rounded-lg border border-slate-800 bg-slate-950/40 p-6 text-center text-sm text-slate-400">
            حدّد موقعك أولاً لعرض المواقيت
          </div>`;
        locLabel.textContent = '— لم يُحدّد بعد —';
        $('pt-next-name').textContent = '—';
        $('pt-next-in').textContent = '—';
        $('pt-qibla-deg').textContent = '— °';
        return;
      }

      locLabel.textContent = state.label || `${state.lat.toFixed(3)}, ${state.lon.toFixed(3)}`;

      const coords = new Coordinates(state.lat, state.lon);
      const params = paramsFor(state.method, state.madhab);
      const now = new Date();
      const times = new PrayerTimes(coords, now, params);

      const rows: { key: keyof typeof PRAYER_LABELS_AR; t: Date }[] = [
        { key: 'fajr', t: times.fajr },
        { key: 'sunrise', t: times.sunrise },
        { key: 'dhuhr', t: times.dhuhr },
        { key: 'asr', t: times.asr },
        { key: 'maghrib', t: times.maghrib },
        { key: 'isha', t: times.isha },
      ];

      // Find next prayer (not sunrise)
      const PRAYER_ONLY = ['fajr', 'dhuhr', 'asr', 'maghrib', 'isha'] as const;
      const next = rows.find((r) => PRAYER_ONLY.includes(r.key as any) && r.t.getTime() > now.getTime());

      const container = $('pt-times');
      container.innerHTML = rows.map((r) => {
        const isNext = next && r.key === next.key;
        return `
          <div class="rounded-xl border ${isNext ? 'border-emerald-500 bg-emerald-500/10' : 'border-slate-800 bg-slate-900/40'} p-4 text-center">
            <p class="text-xs uppercase tracking-wider ${isNext ? 'text-emerald-300' : 'text-slate-500'}">${PRAYER_LABELS_AR[r.key]}</p>
            <p class="mt-2 text-2xl font-bold ${isNext ? 'text-white' : 'text-slate-200'} tabular-nums">${arDigits(formatTime24(r.t))}</p>
          </div>`;
      }).join('');

      if (next) {
        $('pt-next-name').textContent = PRAYER_LABELS_AR[next.key];
        updateCountdown(next.t);
      } else {
        // Past Isha — show fajr of tomorrow
        const tomorrow = new Date(now);
        tomorrow.setDate(tomorrow.getDate() + 1);
        const tmr = new PrayerTimes(coords, tomorrow, params);
        $('pt-next-name').textContent = PRAYER_LABELS_AR.fajr + ' (غداً)';
        updateCountdown(tmr.fajr);
      }

      // Qibla
      const bearing = qiblaBearing(state.lat, state.lon);
      $('pt-qibla-deg').textContent = `${arDigits(bearing.toFixed(1))} °`;
      staticRotate = bearing;
      applyCompassRotation();
    }

    let countdownTimer: number | null = null;
    function updateCountdown(target: Date) {
      if (countdownTimer) window.clearInterval(countdownTimer);
      const tick = () => {
        const diff = target.getTime() - Date.now();
        if (diff <= 0) { compute(); return; }
        const h = Math.floor(diff / 3_600_000);
        const m = Math.floor((diff % 3_600_000) / 60_000);
        const s = Math.floor((diff % 60_000) / 1000);
        const parts: string[] = [];
        if (h > 0) parts.push(`${arDigits(h)} ساعة`);
        parts.push(`${arDigits(m)} دقيقة`);
        if (h === 0) parts.push(`${arDigits(s)} ثانية`);
        $('pt-next-in').textContent = 'بعد ' + parts.join(' و');
      };
      tick();
      countdownTimer = window.setInterval(tick, 1000);
    }

    // Geolocation
    $('pt-use-location').addEventListener('click', () => {
      clearError();
      if (!navigator.geolocation) {
        showError('المتصفح لا يدعم تحديد الموقع.');
        return;
      }
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          state.lat = pos.coords.latitude;
          state.lon = pos.coords.longitude;
          state.label = 'موقعي الحالي';
          save(state);
          compute();
        },
        (e) => {
          showError('تعذّر تحديد الموقع: ' + (e.message || 'الإذن مرفوض'));
        },
        { enableHighAccuracy: false, timeout: 10000, maximumAge: 300000 },
      );
    });

    // City picker
    citySel.addEventListener('change', (e) => {
      const val = (e.target as HTMLSelectElement).value;
      if (!val) return;
      const [lat, lon] = val.split(',').map(Number);
      const opt = (e.target as HTMLSelectElement).selectedOptions[0];
      state.lat = lat;
      state.lon = lon;
      state.label = `${opt.dataset.nameAr} · ${opt.dataset.country}`;
      save(state);
      compute();
    });

    methodSel.addEventListener('change', (e) => {
      state.method = (e.target as HTMLSelectElement).value;
      save(state);
      compute();
    });
    madhabSel.addEventListener('change', (e) => {
      state.madhab = (e.target as HTMLSelectElement).value as 'Shafi' | 'Hanafi';
      save(state);
      compute();
    });

    // Qibla compass (DeviceOrientation)
    let compassActive = false;
    let deviceHeading = 0; // 0-360, 0 = north
    let staticRotate = 0;

    function applyCompassRotation() {
      const arrow = $('pt-compass-arrow');
      const rot = compassActive ? staticRotate - deviceHeading : staticRotate;
      arrow.style.transform = `rotate(${rot}deg)`;
    }

    function onDeviceOrientation(e: DeviceOrientationEvent) {
      // iOS: webkitCompassHeading (0-360, true north)
      // Others: alpha (0-360, counter-clockwise, magnetic)
      const heading = (e as any).webkitCompassHeading ?? (e.alpha != null ? 360 - e.alpha : null);
      if (heading == null) return;
      deviceHeading = heading;
      applyCompassRotation();
    }

    $('pt-compass-toggle').addEventListener('click', async () => {
      if (compassActive) {
        compassActive = false;
        window.removeEventListener('deviceorientation', onDeviceOrientation as any);
        window.removeEventListener('deviceorientationabsolute', onDeviceOrientation as any);
        $('pt-compass-toggle').textContent = 'تفعيل البوصلة المباشرة (للهاتف)';
        applyCompassRotation();
        return;
      }
      // iOS 13+ requires permission
      const Req = (DeviceOrientationEvent as any).requestPermission;
      if (typeof Req === 'function') {
        try {
          const res = await Req();
          if (res !== 'granted') { showError('تم رفض إذن البوصلة.'); return; }
        } catch { showError('تعذّر طلب إذن البوصلة.'); return; }
      }
      compassActive = true;
      window.addEventListener('deviceorientationabsolute', onDeviceOrientation as any, true);
      window.addEventListener('deviceorientation', onDeviceOrientation as any, true);
      $('pt-compass-toggle').textContent = 'إيقاف البوصلة';
    });

    // Initial render
    compute();
    // Re-compute on visibility change (midnight rollover etc.)
    document.addEventListener('visibilitychange', () => { if (!document.hidden) compute(); });
  </script>
</BaseLayout>
