---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { juzBoundaries } from '../../lib/juz.ts';
import { arabicDigits, shortSurahName } from '../../lib/quran.ts';

const title = 'أجزاء القرآن الكريم — ٣٠ جزء كامل';
const description = 'تصفح القرآن الكريم مقسماً إلى ثلاثين جزءاً لقراءة منتظمة على مدار الشهر.';
---
<BaseLayout title={title} description={description}>
  <section class="border-b border-slate-800/60">
    <div class="mx-auto max-w-5xl px-4 pt-14 pb-10 sm:px-6 md:pt-20">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-wider text-emerald-400">الأجزاء</p>
        <h1 class="mt-3 text-4xl font-bold text-white md:text-5xl">أجزاء القرآن</h1>
        <p class="mx-auto mt-4 max-w-xl text-slate-300">
          ٣٠ جزءًا — جزء لكل يوم من رمضان، أو برنامج قراءة منتظم على مدار الشهر.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <ul class="grid grid-cols-1 gap-2.5 sm:grid-cols-2 lg:grid-cols-3">
      {juzBoundaries.map((j) => (
        <li>
          <a
            href={`/juz/${j.juz}/`}
            class="group flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/40 p-4 transition hover:border-emerald-500/60 hover:bg-slate-900/80"
          >
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-emerald-500/30 bg-emerald-500/5 text-lg font-bold text-emerald-400 arabic-num">
              {arabicDigits(j.juz)}
            </div>
            <div class="min-w-0 flex-1">
              <p class="font-semibold text-white">الجزء {arabicDigits(j.juz)}</p>
              <p class="mt-0.5 truncate text-xs text-slate-400">
                من {shortSurahName(j.startSurahName)} · آية {arabicDigits(j.startAyah)}
              </p>
              <p class="truncate text-xs text-slate-500">
                إلى {shortSurahName(j.endSurahName)} · صفحات {arabicDigits(j.startPage)}–{arabicDigits(j.endPage)}
              </p>
            </div>
            <svg class="h-4 w-4 shrink-0 rotate-180 text-slate-600 transition group-hover:text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
