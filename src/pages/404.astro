---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="الصفحة غير موجودة - القرآن الكريم"
  description="عذراً، الصفحة التي تبحث عنها غير موجودة."
>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <p class="text-7xl font-bold text-emerald-500 md:text-8xl">٤٠٤</p>
    <h1 class="mt-6 text-3xl font-bold text-white md:text-4xl">الصفحة غير موجودة</h1>
    <p class="mt-3 text-slate-400">
      الرابط الذي فتحته غير صحيح أو تم نقل الصفحة.
    </p>
    <a href="/" class="mt-8 inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-900 transition hover:bg-emerald-400">
      العودة إلى الصفحة الرئيسية
    </a>
  </section>
</BaseLayout>
